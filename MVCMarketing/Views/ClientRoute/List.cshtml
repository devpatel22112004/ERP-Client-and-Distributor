@{
    ViewBag.Title = "Client Route List";
    Layout = Session["Layout"].ToString();

}

<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2" id="filter_ClientRoute">
            <span class="text-sm">Search Record</span>
            <div class="row">
                <div class="col-md-2">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="0" id="txtSearchWeekDay" name="txtSearchWeekDay" placeholder="Type Week Day">
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="1" id="txtSearchRoutename" name="txtSearchRoutename" placeholder="Type Route Name">
                    </div>
                </div>
                <div class="col-md-2">
                    <span id="btnListSearch" class="btn btn-outline-secondary btn-sm" title="Filter"><i class="fas fa-filter"></i></span>
                    <span id="btnListRefresh" class="btn btn-outline-secondary btn-sm" title="Reset"><i class="fas fa-sync-alt"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header border-0">
                <h3 class="card-title">Client Route List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormRoute" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <!-- /.card-header -->
            <div class="card-body table-responsive small p-2" style="height: 70vh;">
                <table class="table table-striped table-sm no-footer table-borderless table-hover table-head-fixed table-responsive-card" id="myTableClientRoute">
                    <thead>
                        <tr>
                            <th>Week Day</th>
                            <th>Route Name</th>
                            <th>Route Number</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>
@section footer{
    <script>
        var oTableClientRoute;
        function filterColumn(i, tag) {
            oTableClientRoute.DataTable().column(i).search(
                tag.val()
            ).draw();
        }
        $(function () {
            $(".master,.master-route,.master-route-client").addClass('active');

            /* Aditional Filter */
            $('input.column_filter,select.column_filter').on('keyup change', function () {
                filterColumn($(this).attr('data-column'), $(this));
            });

            $('#btnFormRoute').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New Route", "/ClientRoute/Form", "modal-md");
            });

            BindTableClientRoute();// Bind table

            //refresh button
            $('#btnListRefresh').click(function () {
                oTableClientRoute.DataTable().state.clear();
                location.reload();
            });

        });

        function BindTableClientRoute() {
            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "View";
            oTableClientRoute = bindTableSmart($('#myTableClientRoute'), activeButtonClass, "/ClientRoute/LoadData", "null", $("#filter_ClientRoute")); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableClientRoute.on('click', '.view-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Info?id=" + recordId, "modal-xl");// Model Size : modal-sm modal-md modal-lg
            });
        }

    </script>

}

