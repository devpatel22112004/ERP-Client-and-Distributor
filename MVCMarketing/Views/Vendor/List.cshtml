@{
    ViewBag.Title = "Vendor List";
    Layout = Session["Layout"].ToString();
}
<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2" id="filter_Vendor">
            <span class="text-sm">Search Record</span>
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="1" id="txtSearchVendorCode" name="txtSearchVendorCode" placeholder="Type Vendor Code">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="0" id="txtSearchVendor" name="txtSearchVendor" placeholder="Type Vendor">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="2" id="txtSearchPhone" name="txtSearchPhone" placeholder="Type Phone">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="3" id="txtSearchCity" name="txtSearchCity" placeholder="Type City">
                    </div>
                </div>
                <div class="col-md-2">
                    <span id="btnListSearch" class="btn btn-outline-secondary btn-sm" title="Filter"><i class="fas fa-filter"></i></span>
                    <span id="btnListRefresh" class="btn btn-outline-secondary btn-sm" title="Reset"><i class="fas fa-sync-alt"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Vendor List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormVendor" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <!-- /.card-header -->
            <div class="card-body small p-2" style="height: 70vh;">
                <!--class="card-body table-responsive p-0" style="height: 300px;" nowrap -->
                <table class="table table-striped table-sm no-footer table-borderless table-hover table-head-fixed table-responsive-card" id="myTableVendor">
                    <!--table table-head-fixed-->
                    <thead>
                        <tr>
                            <th>Vendor Code</th>
                            <th>Vendor</th>
                            <th>Person</th>
                            <th>Contact</th>
                            <th>Email</th>
                            <th>City</th>
                            <th>State</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>
@section footer{
    <script>
        var oTableVendor;
        function filterColumn(i, tag) {
            oTableVendor.DataTable().column(i).search(
                tag.val()
            ).draw();
        }
        $(document).ready(function () {
            $(".master,.master-vendor").addClass('active');

            /* Aditional Filter */
            $('input.column_filter,select.column_filter').on('keyup change', function () {
                filterColumn($(this).attr('data-column'), $(this));
            });

            BindTableVendor();// Bind table

            //refresh button
            $('#btnListRefresh').click(function () {
                oTableVendor.DataTable().state.clear();
                location.reload();
            });

            $('#btnFormVendor').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New Vendor", "/Vendor/Form", "modal-xl");
            });
        });

        function BindTableVendor() {

            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "Edit";
            oTableVendor = bindTableSmart($('#myTableVendor'), activeButtonClass, "/Vendor/LoadData", "null", $("#filter_Vendor")); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableVendor.on('click', '.edit-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Edit?id=" + recordId, "modal-xl");// Model Size : modal-sm modal-md modal-lg
            });

        }
    </script>

}






