@{
    var InfoJson = ViewBag.JsonData;
}
<div class="p-2">
    <form role="form" data-toggle="validator" id="formExpense" class="text-sm">
        <div class="row">
            <div class="col-12 text-center bg-transparent">
                <span class="delete-record-message" id="btnDeleteExpense"> DELETE PERMANENT RECORDS ? CLICK HERE  <i class="far fa-trash-alt delete-record text-red" title="Delete Record"></i></span>
            </div>
            <div class="form-group col-md-6">
                <span for="txtDate">Date<i class="text-red" title="Required">*</i></span>
                <input type="text" class="form-control form-control-sm" id="txtDate" name="txtDate" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" data-focus="flase" required>
            </div>
            <div class="form-group col-md-6">
                <span for="ddPaymentMode">Payment Mode<i class="text-red" title="Required">*</i></span>
                <select class="form-control form-control-sm select3" id="ddPaymentMode" name="ddPaymentMode" data-error="Please Select PaymentMode" autofocus required>
                    <option value="">-- Select Payment Mode ---</option>
                    <option value="Cheque">Cheque</option>
                    <option value="Cash">Cash</option>
                    <option value="Online">Online</option>
                    <option value="UPI">UPI</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <span for="ddCategory">Category<i class="text-red" title="Required">*</i></span>
                    <select class="form-control form-control-sm input-sm select3" id="ddCategory" name="ddCategory" title="Please Selected Category" required>
                        <option value="" selected="selected">-----Selected------</option>
                    </select>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <span for="ddSubCategory">Sub Category<i class="text-red" title="Required">*</i></span>
                    <select class="form-control form-control-sm input-sm select3" id="ddSubCategory" name="ddSubCategory" title="Please Selected Sub Category" required>
                        <option value="" selected="selected">-----Selected------</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="form-group col-md-6">
                <span for="ddEmployee">Employee</span>
                <select class="form-control form-control-sm input-sm select3" id="ddEmployee" name="ddEmployee" title="Please Selected Employee">
                    <option value="" selected="selected">-----Selected------</option>
                </select>
            </div>
            <div class="form-group col-md-6">
                <span for="txtAmount">Amount<i class="text-red" title="Required">*</i></span>
                <input type="text" class="form-control  form-control-sm" id="txtAmount" name="txtAmount" placeholder="Enter Amount" data-error="Please Fill Up Amount" pattern="[0-9]+(\.[0-9]{0,3})?%?" required>
            </div>
        </div>
        <div class="row hidden" id="dvCheque">
            <div class="form-group col-md-6">
                <span for="txtChequeNo">Cheque No<i class="text-red" title="Required">*</i></span>
                <input type="text" class="form-control form-control-sm" id="txtChequeNo" name="txtChequeNo" placeholder="Enter Cheque Name" data-error="Please Fill Up Cheque No">
            </div>
            <div class="form-group col-md-6">
                <span for="txtChequeName">Cheque Name<i class="text-red" title="Required">*</i></span>
                <input type="text" class="form-control form-control-sm" id="txtChequeName" name="txtChequeName" placeholder="Enter Cheque Name" data-error="Please Fill Up Cheque Name">
            </div>
        </div>
        <div class="row">
            <div class="form-group col-md-12">
                <span for="txtRemark">Remark</span>
                <input type="text" class="form-control form-control-sm" id="txtRemark" name="txtRemark" placeholder="Enter Remark" data-error="Please Fill Up Remark">
            </div>
        </div>
        <div class="col-12 text-center">
            <hr />
            <input type="hidden" value="" id="hdId" name="hdId" />
            <button type="submit" class="col-md-3 btn btn-outline-secondary btn-sm">Save</button>
        </div>
    </form>
</div>
<script>
    $(function () {

        //Date picker
        $('#txtDate').datepicker({
            format: "dd-mm-yyyy",
            todayHighlight: true,
            autoclose: true
        });
        $('#txtDate').inputmask('dd-mm-yyyy', { 'placeholder': 'dd-mm-yyyy' });

        /* Bind Brand */
        bindDropDownList($('#ddCategory'), 'ExpenseCategory');

        bindDropDownList($('#ddEmployee'), 'Employee');

        /* Bind Sub Cateory */
        $("#ddCategory").change(function () {
            var selectedValue = $(this).val();
            bindDropDownList($('#ddSubCategory'), 'ExpenseSubCategory', selectedValue);
        });

        $("#ddPaymentMode").change(function (event) {
            var selectedText = $(this).find("option:selected").text();
            if (selectedText == 'Cheque') {
                $("#txtChequeNo,#txtChequeName").attr("required", "required");
                $("#dvCheque").removeClass("hidden");
            }
            else {
                $("#txtChequeNo,#txtChequeName").removeAttr("required");
                $("#dvCheque").addClass("hidden");
                $("#txtChequeNo,#txtChequeName").val("");
            }
        });

        /*Edit Record */
        var jInfo = @Html.Raw(InfoJson);
        console.log(jInfo);
        if (jInfo != null) {
            $("#hdId").val(jInfo[0].ExpenseId);
            $("#txtDate").val(jInfo[0].Date);
            $("#ddCategory").val(jInfo[0].ExpenseCategoryId);
            $("#ddPaymentMode").val(jInfo[0].PaymentMode);
            $("#txtAmount").val(jInfo[0].Amount);
            if (jInfo[0].PaymentMode == "Cheque") {
                    $("#dvCheque").attr("required", "required");
                    $("#dvCheque").removeClass("hidden");
            }
            $("#txtChequeNo").val(jInfo[0].ChequeNo);
            $("#txtChequeName").val(jInfo[0].ChequeName);
            $("#txtTag").val(jInfo[0].Tag);
            $("#txtRemark").val(jInfo[0].Remark);
            $("#ddEmployee").val(jInfo[0].EmployeeId);
            bindDropDownList($('#ddSubCategory'), 'ExpenseSubCategory', jInfo[0].ExpenseCategoryId).then(function (res) {
                 $("#ddSubCategory").val(jInfo[0].ExpenseSubCategoryId );
            });
        }
        /* end:Edit Record */

        /* start Form validation & save data */
        var f = $('#formExpense');
        f.validator();// Call validation function
        f.attr('autocomplete', 'off');//Auto Complete Off
        f.submit(function (e) {
            e.preventDefault();
            var button = f.find(':submit');
            var isDisabled = button.is('.btn.disabled');
            var redirectUrl = '/Expense/List'; // Eg /Branch/List
            if (isDisabled) {
                return;
            }
            else {
                sendData(f, "/Expense/Insert", button, button.text(), redirectUrl).then(function (res) {
                    console.log(res)
                });
            }
        });
        /* end Form */

        //Item AutoComplete
        //customAutoCompleteDynamic($('#txtProjectName'), $('#hdProjectId'), "Project", AutoCompleteClientResult);

        /*Delete Action*/
        $('#btnDeleteExpense').on('click', function(e){
            confirmDialog('Are you sure to delete record ?', function () {
                var recordId = $("#hdId").val();
                sendData($("#formDelete"), "/Expense/Delete?id=" + recordId, $(this), $(this).text(), "/Expense/List");
            });
        });
    });

        /*start : Custom AutoComplete result*/
        /*function AutoCompleteClientResult(e, u) {
             //console("auto complete");
             if (u.item == null) {
                 console.log(u.item);
                 $("#txtProjectName,#hdProjectId").val("");
              }
               else {
                 console.log(u.item);
             }
        }*/

</script>


