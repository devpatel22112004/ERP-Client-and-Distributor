@{
    ViewBag.Title = "Expense List";
    Layout = Session["Layout"].ToString();
}

<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2" id="filter_expense">
            <span class="text-sm">Search Record</span>
            <div class="row">
                <div class="form-group col-md-2">
                    <input type="text" class="form-control form-control-sm column_filter" data-column="0" id="txtSearchDate" name="txtSearchDate" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" placeholder="Please Select Date">
                </div>
                <div class="form-group col-md-2">
                    <select class="form-control form-control-sm input-sm select3 column_filter" data-column="1" id="ddSearchCategory" name="ddSearchCategory" title="Please Selected Category">
                        <option value="" selected="selected">-----Selected Category------</option>
                    </select>
                </div>
                <div class="form-group col-md-2">
                    <select class="form-control form-control-sm input-sm select3 column_filter" data-column="2" id="ddSearchSubCategory" name="ddSearchSubCategory" title="Please Selected Sub Category">
                        <option value="" selected="selected">-----Selected Sub Category------</option>
                    </select>
                </div>
                <div class="form-group col-md-2">
                    <select class="form-control form-control-sm input-sm select3 column_filter" data-column="4" id="ddSearchEmployee" name="ddSearchEmployee" title="Please Selected Employee">
                        <option value="" selected="selected">-----Selected Employee------</option>
                    </select>
                </div>
                <div class="form-group col-md-2">
                    <select class="form-control form-control-sm select3 column_filter" data-column="3" id="ddSearchPaymentMode" name="ddSearchPaymentMode" placeholder="Please Select PaymentMode">
                        <option selected="selected" value="">-- Select Payment Mode ---</option>
                        <option value="Cheque">Cheque</option>
                        <option value="Cash">Cash</option>
                        <option value="Online">Online</option>
                        <option value="UPI">UPI</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <span id="btnListSearch" class="btn btn-outline-secondary btn-sm" title="Filter"><i class="fas fa-filter"></i></span>
                    <span id="btnListRefresh" class="btn btn-outline-secondary btn-sm" title="Reset"><i class="fas fa-sync-alt"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Expense List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormExpense" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <!-- /.card-header -->
            <div class="small card-body p-2">
                <table class="table table-striped table-sm no-footer table-borderless table-hover table-head-fixed table-responsive-card" id="myTableExpense">
                    <!--table table-head-fixed-->
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Sub Category</th>
                            <th>Payment Mode</th>
                            <th>Employee</th>
                            <th>Cheque No</th>
                            <th>Cheque Name</th>
                            <th>Remark</th>
                            <th>Amount</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>
@section footer{
    <script>
        var oTableExpense;

        function filterColumn(i, tag) {
            oTableExpense.DataTable().column(i).search(
                tag.val()
            ).draw();
        }
        $(function () {
            $(".Account,.account-daybook,.account-expense").addClass('active');

            /* Aditional Filter */
            $('input.column_filter,select.column_filter').on('keyup change', function () {
                filterColumn($(this).attr('data-column'), $(this));
            });

            $('#txtSearchDate').datepicker({
                format: "dd-mm-yyyy",
                todayHighlight: true,
                autoclose: true
            });

            bindDropDownList($('#ddSearchCategory'), 'ExpenseCategory');

            bindDropDownList($('#ddSearchEmployee'), 'Employee');

            /* Bind Sub Cateory */
            $("#ddSearchCategory").change(function () {
                var selectedValue = $(this).val();
                bindDropDownList($('#ddSearchSubCategory'), 'ExpenseSubCategory', selectedValue);
            });

            BindTableExpense(); // Bind table

            //refresh button
            $('#btnListRefresh').click(function () {
                oTableExpense.DataTable().state.clear();
                location.reload();
            });

            $('#btnFormExpense').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New Expense", "/Expense/Form", "modal-lg");
            });
        });

        function BindTableExpense() {
            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "Edit";
            oTableExpense = bindTableSmart($('#myTableExpense'), activeButtonClass, "/Expense/LoadData", "null", $("#filter_expense")); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableExpense.on('click', '.edit-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Edit?id=" + recordId, "modal-lg");// Model Size : modal-sm modal-md modal-lg
            });
        }
    </script>
}