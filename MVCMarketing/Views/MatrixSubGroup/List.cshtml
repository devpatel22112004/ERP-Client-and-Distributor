@{
    ViewBag.Title = "Matrix Sub Group List";
    Layout = Session["Layout"].ToString();
}

<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2">
            <span class="text-sm">Search Record</span>
            <div class="row">
                <div class="col-md-7">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm" id="txtSearchMatrixSubGroup" name="txtSearchMatrixSubGroup" placeholder="Type Area Name">
                    </div>
                </div>
                <div class="col-md-2">
                    <span id="btnListSearch" class="btn btn-outline-secondary btn-sm" title="Filter"><i class="fas fa-filter"></i></span>
                    <span id="btnListRefresh" class="btn btn-outline-secondary btn-sm" title="Reset"><i class="fas fa-sync-alt"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header border-0">
                <h3 class="card-title">Matrix Area List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormMatrixSubGroup" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <!-- /.card-header -->
            <div class="card-body small p-2" style="height: 70vh;">
                <!--class="card-body table-responsive p-0" style="height: 300px;"-->
                <table class="table table-striped table-sm no-footer table-borderless table-hover table-head-fixed table-responsive-card" id="myTableMatrixSubGroup">
                    <!--table table-head-fixed-->
                    <thead>
                        <tr>
                            <th>Area</th>
                            <th>Sub Area</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>
@section footer{
    <script>
        $(function () {
            $(".master,.master-matrix, .master-matrix-Sub-group").addClass('active');

            BindTableMatrixSubGroup();// Bind table

            //refresh button
            $('#btnListRefresh').click(function () {
                location.reload();
            });

            $('#btnFormMatrixSubGroup').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New Matrix Sub Area", "/MatrixSubGroup/Form", "modal-md");
            });
        });

        function BindTableMatrixSubGroup() {
            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "Edit";
            var oTableMatrixSubGroup = bindTable($('#myTableMatrixSubGroup'), activeButtonClass, "/MatrixSubGroup/LoadMatrixSubGroupData"); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableMatrixSubGroup.on('click', '.edit-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Edit?id=" + recordId, "modal-md");// Model Size : modal-sm modal-md modal-lg
            });
            //Search bar
            $("#txtSearchMatrixSubGroup").on('keyup change', function (e) {
                var thisId = $(this).attr("Id");
                if (e.which == 13 || thisId.includes("dd")) {
                    $('#btnListSearch').trigger('click');
                }
            });
            //Apply Custom search on jQuery DataTables here
            $('#btnListSearch').click(function () {
                oTableMatrixSubGroup.columns(0).search($('#txtSearchMatrixSubGroup').val().trim().replaceAll(' ', '%'));
                oTableMatrixSubGroup.draw();
            });
        }

    </script>

}






