@{
    ViewBag.Title = "Branch List";

}

<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2" id="filter_Branch">
            <span class="text-sm">Search Record</span>
            <div class="row">
                <div class="col-md-2">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="0" id="txtSearchBranchName" name="txtSearchBranchName" placeholder="Type Branch Name">
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="1" id="txtSearchPersonName" name="txtSearchPersonName" placeholder="Type Person Name">
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="2" id="txtSearchContact" name="txtSearchContact" placeholder="Type Contact">
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group text-sm">
                        <select class="form-control form-control-sm select3 column_filter" data-column="3" id="ddSearchStatus" name="ddSearchStatus" title="Please Select Status">
                            <option selected="selected" value="">-- Select Status ---</option>
                            <option value="TRUE">Active</option>
                            <option value="FALSE">Deactive</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <span id="btnListSearch" class="btn btn-outline-secondary btn-sm" title="Filter"><i class="fas fa-filter"></i></span>
                    <span id="btnListRefresh" class="btn btn-outline-secondary btn-sm" title="Reset"><i class="fas fa-sync-alt"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Branch List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormBranch" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <!-- /.card-header -->
            <div class="card-body small table-responsive p-2" style="height: 70vh;">
                <table class="table table-striped table-sm no-footer table-borderless table-hover table-head-fixed table-responsive-card" id="myTableBranch">
                    <!--table table-head-fixed-->
                    <thead>
                        <tr>
                            <th>Branch Name</th>
                            <th>Address</th>
                            <th>Person Name</th>
                            <th>Contact</th>
                            <th>Email</th>
                            <th>GST Number</th>
                            <th>PAN</th>
                            <th>BankDetail</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>
@section footer{
    <script>
        var oTableBranch;
        function filterColumn(i, tag) {
            oTableBranch.DataTable().column(i).search(
                tag.val()
            ).draw();
        }
        $(function () {
            $(".master,.master-Branch").addClass('active');

            /* Aditional Filter */
            $('input.column_filter,select.column_filter').on('keyup change', function () {
                filterColumn($(this).attr('data-column'), $(this));
            });

            BindTableBranch(); // Bind table

            //refresh button
            $('#btnListRefresh').click(function () {
                oTableBranch.DataTable().state.clear();
                location.reload();
            });

            $('#btnFormBranch').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New Branch", "/Branch/Form", "modal-lg");
            });
        });

        function BindTableBranch() {
            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "Edit,Image";
            oTableBranch = bindTableSmart($('#myTableBranch'), activeButtonClass, "/Branch/LoadData", "null", $("#filter_Branch")); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableBranch.on('click', '.edit-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Edit?id=" + recordId, "modal-lg");// Model Size : modal-sm modal-md modal-lg
            });

            oTableBranch.on('click', '.image-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(2).text();
                viewPartialViewModal(recordTitle, "Image?id=" + recordId, "modal-xl");// Model Size : modal-sm modal-md modal-lg
            });
            //oTableBranch.on('click', '.image-record', function () {
            //    //var recordId = $(this).closest("td").find("input[type='hidden']").val();
            //    var recordId = $(this).attr('data-id');
            //    var recordTitle = $(this).closest("tr").find("td").eq(2).text();
            //    // viewPartialViewModal(recordTitle, "Token?id=" + recordId, "modal-xl");// Model Size : modal-sm modal-md modal-lg
            //    viewNestedModalPartialView(recordTitle, "/Branch/Upload?id=" + recordId, "modal-xl");// Model Size : modal-sm modal-md modal-lg
            //});
        }
    </script>
}
