@{
    ViewBag.Title = "Expense SubCategory List";
    Layout = Session["Layout"].ToString();
}

<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2" id="filter_ExpenseSubCategory">
            <span class="text-sm">Search Record</span>
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group text-sm">
                        <select class="form-control form-control-sm input-sm select3 column_filter" data-column="0" id="ddSearchCategory" name="ddSearchCategory" title="Please Selected Category">
                            <option value="" selected="selected">-----Selected Category------</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="1" id="txtSearch" name="txtSearch" placeholder="Type Label">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group text-sm">
                        <select class="form-control form-control-sm select3 column_filter" data-column="2" id="ddSearchStatus" name="ddSearchStatus" title="Please Select Status">
                            <option selected="selected" value="">-- Select Status ---</option>
                            <option value="TRUE">Active</option>
                            <option value="FALSE">Deactive</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <span id="btnListSearch" class="btn btn-outline-secondary btn-sm" title="Filter"><i class="fas fa-filter"></i></span>
                    <span id="btnListRefresh" class="btn btn-outline-secondary btn-sm" title="Reset"><i class="fas fa-sync-alt"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Expense SubCategory List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormExpenseSubCategory" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <!-- /.card-header -->
            <div class="small card-body p-2" style="height: 70vh;">
                <table class="table table-striped table-sm no-footer table-borderless table-hover table-head-fixed table-responsive-card" id="myTableExpenseSubCategory">
                    <!--table table-head-fixed-->
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Label</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>
@section footer{
    <script>
        var oTableExpenseSubCategory;

        function filterColumn(i, tag) {
            oTableExpenseSubCategory.DataTable().column(i).search(
                tag.val()
            ).draw();
        }


        $(function () {
            $(".master,.master-expense,.master-expense-subcategory").addClass('active');

            /* Bind Brand */
            bindDropDownList($('#ddSearchCategory'), 'ExpenseCategory');

            BindTableExpenseSubCategory(); // Bind table

            /* Aditional Filter */
            $('input.column_filter,select.column_filter').on('keyup change', function () {
                filterColumn($(this).attr('data-column'), $(this));
            });

            //refresh button
            $('#btnListRefresh').click(function () {
                oTableExpenseSubCategory.DataTable().state.clear();
                location.reload();
            });

            $('#btnFormExpenseSubCategory').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New ExpenseSubCategory", "/ExpenseSubCategory/Form", "modal-md");
            });
        });

        function BindTableExpenseSubCategory() {
            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "Edit";
            oTableExpenseSubCategory = bindTableSmart($('#myTableExpenseSubCategory'), activeButtonClass, "/ExpenseSubCategory/LoadData", "null", $("#filter_ExpenseSubCategory")); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableExpenseSubCategory.on('click', '.edit-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Edit?id=" + recordId, "modal-md");// Model Size : modal-sm modal-md modal-lg
            });

        }
    </script>
}