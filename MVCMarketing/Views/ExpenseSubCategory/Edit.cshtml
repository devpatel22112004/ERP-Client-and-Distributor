@{
    var InfoJson = ViewBag.JsonData;
}
<div class="p-2">
    <form role="form" data-toggle="validator" id="formExpenseSubCategory" class="text-sm">
        <div class="row">
            <div class="form-group col-md-12">
                <span for="ddCategory">Category<i class="text-red" title="Required">*</i></span>
                <select class="form-control form-control-sm input-sm select3" id="ddCategory" name="ddCategory" title="Please Selected Category" required>
                    <option value="" selected="selected">-----Selected------</option>
                </select>
            </div>
            <div class="form-group col-md-12">
                <span for="txtLabel">Label <i class="text-red" title="Required">*</i></span>
                <input type="text" class="form-control" id="txtLabel" name="txtLabel" placeholder="Enter Label" data-error="Please Fill Up Label" required>
            </div>
            <div class="form-group col-md-12">
                <span for="ddStatus">Status <i class="text-red" title="Required">*</i></span>
                <select class="form-control select3" id="ddStatus" name="ddStatus" data-error="Please Select Status" required>
                    <option selected="selected" value="">-- Select Status ---</option>
                    <option value="TRUE">Active</option>
                    <option value="FALSE">Deactive</option>
                </select>
            </div>
        </div>
        <div class="col-12 text-center">
            <hr />
            <input type="hidden" value="" id="hdId" name="hdId" />
            <button type="submit" class="col-md-3 btn btn-outline-secondary btn-sm">Save</button>
        </div>
    </form>
</div>
<script>

    $(function () {
        /* Bind Brand */
        bindDropDownList($('#ddCategory'), 'ExpenseCategory');
        /*Edit Record */
        var jInfo = @Html.Raw(InfoJson);
        console.log(jInfo);
        if (jInfo != null) {
            $("#hdId").val(jInfo[0].ExpenseSubId);
            $("#txtLabel").val(jInfo[0].Label);
            $("#ddStatus").val(jInfo[0].Status);
            $("#ddCategory").val(jInfo[0].ExpenseCategoryId);
        }
        /* end:Edit Record */

        

        /* start Form validation & save data */
        var f = $('#formExpenseSubCategory');
        f.validator();// Call validation function
        f.attr('autocomplete', 'off');//Auto Complete Off
        f.submit(function (e) {
            e.preventDefault();
            var button = f.find(':submit');
            var isDisabled = button.is('.btn.disabled');
            var redirectUrl = '/ExpenseSubCategory/List'; // Eg /Branch/List
            if (isDisabled) {
                return;
            }
            else {
                sendData(f, "/ExpenseSubCategory/Insert", button, button.text(), redirectUrl).then(function (res) {
                    console.log(res)
                });
            }
        });
        /* end Form */
    });


</script>



