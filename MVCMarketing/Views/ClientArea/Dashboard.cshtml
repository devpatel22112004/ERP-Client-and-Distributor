
@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_LayoutClient.cshtml";
}

<div class="row">
    <div class="col-md-4">
        <div class="row">
            <div class="col-md-12 small-box bg-primary p-2">
                <b><span class="small">CLIENT : </span><span class="lbclient"></span></b>
            </div>
            <div class="col-md-12 small-box bg-info p-2">
                <div><span class="small">DEALER :</span> <span class="lbdealer"></span></div>
                <div><span class="small">PERSON :</span> <span class="lbdealerperson"></span></div>
            </div>
            <div class="col-md-12 small-box bg-green p-2">
                <b><span class="small">PHONE :</span><span class="lbdealercontact pointer"></span></b>
            </div>
        </div>
        <div class="row">
            <div class="card col-md-12">
                <div class="card-header with-border">
                    <h3 class="card-title">Pending Amount</h3>
                </div>
                <!-- /.box-header -->
                <div class="card-body no-padding table-responsive small" style="height: 20vh;">
                    <table class="table table-striped table-sm small no-footer table-borderless table-hover table-head-fixed" id="myTablePendingAmount">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th>Amount</th>
                                <th>Paid</th>
                                <th>Remaining</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-5">
                        <div class="form-group">
                            <input type="text" class="form-control form-control-sm" id="txtSearchStartDate" name="txtSearchStartDate" placeholder="Search Start Date" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" data-focus="flase">
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="form-group">
                            <input type="text" class="form-control form-control-sm" id="txtSearchEndDate" name="txtSearchEndDate" placeholder="Search End Date" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" data-focus="flase">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <span id="btnListSearchModel" class="btn btn-outline-secondary btn-sm" title="Filter"><i class="fas fa-filter"></i></span>
                        <span id="btnListRefreshModel" class="btn btn-outline-secondary btn-sm" title="Reset"><i class="fas fa-sync-alt"></i></span>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="row">
                    <div class="col-md-12 text-right">
                        <h6>Opening Bal.  <span id="lbOpening">0.0</span></h6>
                    </div>
                    <div class="table-responsive no-padding small" style="height: 40vh;">
                        <table class="table text-center table-striped table-sm small no-footer table-borderless table-hover table-head-fixed" id="myTableAccountLedger">
                            <thead>
                                <tr>
                                    <th style="width: 80px;">Date</th>
                                    <th>Label</th>
                                    <th style="width: 100px;">Debit(₹)</th>
                                    <th style="width: 100px;">Credit(₹)</th>
                                    <th style="width: 100px;">Balance(₹)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                    <div class="col-md-12 text-right">
                        <h6>Closing Bal.  <span id="lbClosing">0.0</span></h6>
                    </div>
                </div>
            </div>
        </div>

    </div>
   
    <div class="col-md-4">
        <div class="card">
            <div class="card-header with-border">
                <h3 class="card-title">Track Delivery ( Last 2 Months )</h3>
            </div>
            <!-- /.box-header -->
            <div class="card-body no-padding table-responsive small" style="height: 40vh;">
                <table class="table table-striped table-sm small no-footer table-borderless table-hover table-head-fixed" id="myTableDeliverClient">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Item</th>
                            <th>Qty</th>
                            <th>Empty</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section footer{
    <script>
        var oTableDeliverClient;
        var tokenId = "";
        var openingBalance;
        $(function () {

            $(".lbdealercontact").on("click", function () {
                let phone = $(this).text().trim();
                if (phone !== "") {
                    window.location.href = "tel:" + phone;
                }
            });

            //Date picker
            $('#txtSearchStartDate,#txtSearchEndDate').datepicker({
                format: "dd-mm-yyyy",
                todayHighlight: true,
                autoclose: true,
                endDate: '+0d'
            });

            oTableAccountLedger = $("#myTableAccountLedger tbody");

            tokenId = '@Html.Raw(ViewBag.TokenId)';
            BindTableDeliverClient();// Bind table
            BindTablePendingAmount();
            //BindTableClientAmount();
            BindDealerInfo();
            BindTableAccountLedger();
            //BindClientPaymentInfo();

            //Set search trigger
            $("#txtSearchStartDate,#txtSearchEndDate").on('keyup change', function (e) {
                var thisId = $(this).attr("Id");
                if (e.which == 13 || thisId.includes("dd")) {
                    $('#btnListSearchModel').trigger('click');
                }
            });
            //Apply Custom search on jQuery DataTables here
            $('#btnListSearchModel').click(function () {
                BindTableAccountLedger();
            });

            $('#btnListRefreshModel').click(function () {
                $('#txtSearchStartDate,#txtSearchEndDate').val('');
                $('#btnListSearchModel').trigger('click');
            });
        });

        function BindTableDeliverClient() {
            $("#myTableDeliverClient > tbody").html("");
            $.ajax(
                {
                    type: "POST", //HTTP POST Method
                    url: "/ClientArea/LoadDataDeliverClient?token=" + tokenId,
                    //data: formData,
                    success: function (data) {
                        debugger;
                        var d = JSON.parse(data.data);
                        //var d = data.data;
                        for (var i = 0; i < d.length; i++) {
                            var row = "";
                            row += "<tr>";
                            row += "<td>" + d[i].Date + "</td>";
                            row += "<td>" + d[i].Item + "</td>";
                            row += "<td>" + d[i].Qty + "</td>";
                            row += "<td>" + d[i].EmptyQty + "</td>";
                            /*row += "<td  width=\"40px\">";
                            row += "<span type=\"button\" class=\"fas fa-file-alt view-record\" title=\"View Record\"></span> <input type=\"hidden\" value='" + d[i].Id + "'>";
                            row += "</td>"*/
                            row += "</tr>";

                            $('#myTableDeliverClient').find("tbody").append(row);
                        }
                    },
                    error: function () {
                        //debugger;
                    }
                });
        }

        function BindTablePendingAmount() {
            $("#myTablePendingAmount > tbody").html("");
            $.ajax(
                {
                    type: "POST", //HTTP POST Method
                    url: "/ClientArea/LoadDataPendingAmount?token=" + tokenId,
                    //data: formData,
                    success: function (data) {
                        
                        var d = data.data;
                        d = JSON.parse(d);
                        debugger;
                        if (d.length == 0) {
                            var row = "";
                            row += "<tr>";
                            row += "<td class=\"text-center\" colspan=\"5\">No Payment Due</td>";
                            row += "</tr>";
                            $('#myTablePendingAmount').find("tbody").append(row);
                            return;
                        }
                        for (var i = 0; i < d.length; i++) {
                            var row = "";
                            row += "<tr>";
                            row += "<td>" + d[i].BillMonthText + "</td>";
                            row += "<td>" + d[i].TotalAmount + "</td>";
                            row += "<td>" + d[i].PaidAmount + "</td>";
                            row += "<td>" + d[i].RemainingAmount + "</td>";
                            row += "<td>" + d[i].PaymentStatus + "</td>";
                            row += "</tr>";
                            $('#myTablePendingAmount').find("tbody").append(row);
                        }
                    },
                    error: function () {
                        //debugger;
                    }
                });
        }

        /*function BindTableClientAmount() {
            $("#myTableClientAmount > tbody").html("");
            $.ajax(
                {
                    type: "POST", //HTTP POST Method
                    url: "/ClientArea/LoadDataClientAmount?token=" + tokenId,
                    //data: formData,
                    success: function (data) {
                        debugger;
                        var d = JSON.parse(data.data);
                        //var d = data.data;
                        for (var i = 0; i < d.length; i++) {
                            var row = "";
                            row += "<tr>";
                            row += "<td>" + d[i].Date + "</td>";
                            row += "<td>" + d[i].Amount + "</td>";
                            row += "</tr>";

                            $('#myTableClientAmount').find("tbody").append(row);
                        }
                    },
                    error: function () {

                    }
                });
        }*/

        function BindDealerInfo() {
            $.ajax(
                {
                    type: "POST", //HTTP POST Method
                    url: "/ClientArea/LoadDataDealerInformation?token=" + tokenId,
                    success: function (data) {
                        var DealerInformation = JSON.parse(data)[0];
                        $(".lbdealer").html(DealerInformation.Name);
                        $(".lbdealerperson").html(DealerInformation.PersonName1);
                        $(".lbdealercontact").html(DealerInformation.Contact1);
                        $(".lbclient").html(DealerInformation.CustomerName);
                    },
                    error: function () {
                    }
                });
        }       


        /*function BindClientPaymentInfo() {
            $.ajax(
                {
                    type: "POST", //HTTP POST Method
                    url: "/ClientArea/LoadDataClientPayment?token=" + tokenId,
                    success: function (data) {
                        var ClientPaymentInformation = JSON.parse(data)[0];
                        $(".lbclientlastmonth").html(ClientPaymentInformation.LastMonth);
                        $(".lbclientcurrentmonth").html(ClientPaymentInformation.CurrentMonth);
                        $(".lbclienttotaldue").html(ClientPaymentInformation.TotalDue);
                    },
                    error: function () {
                    }
                });
        }*/

        function BindTableAccountLedger() {
            oTableAccountLedger.html("");
            $.ajax(
                {
                    type: "POST", //HTTP POST Method
                    url: "/ClientArea/LoadDataLedger?token=" + tokenId + "&StartDate=" + $("#txtSearchStartDate").val() + "&EndDate=" + $("#txtSearchEndDate").val(),
                    //data: formData,
                    success: function (data) {
                        console.log(data);
                        var d = JSON.parse(data.data);
                        console.log(d);
                        openingBalance = JSON.parse(data.openingBalance);
                        console.log(openingBalance);
                        for (var i = 0; i < d.length; i++) {
                            var row = "";
                            row += "<tr>";
                            row += "<td>" + d[i].Date + "</td>";
                            row += "<td>" + d[i].Type + "</td>";
                            row += "<td>" + d[i].Debit + "</td>";
                            row += "<td>" + d[i].Credit + "</td>";
                            row += "<td>" + d[i].Balance + "</td>";                           
                            row += "</tr>";
                            oTableAccountLedger.append(row);
                        }

                        var row0 = oTableAccountLedger.find('tr:first td');
                        // openingBalance =row0.eq(1).text();
                        $("#lbOpening").html("₹ " + openingBalance);

                        var closingBalance = oTableAccountLedger.find('tr:last td').eq(4).text();
                        console.log(closingBalance);
                        debugger;
                        if (parseFloat(closingBalance) > 0) {
                            $("#lbClosing").html("₹ " + closingBalance + "Cr");
                            //$(".lbcurrentoutstanding").html("₹ " + closingBalance + "Cr");
                        }
                        else if (parseFloat(closingBalance) < 0) {
                            $("#lbClosing").html("₹ " + Math.abs(closingBalance.replace(/[^0-9.-]+/g, "")) + " Dr");
                            //$(".lbcurrentoutstanding").html("₹ " + Math.abs(closingBalance) + " Dr");
                        }
                        else {
                            $("#lbClosing").html("₹ 0.00");
                            //$("#lbcurrentoutstanding").html("₹ 0.00");
                        }
                    },
                    error: function () {

                    }
                });
        }
    </script>
}
