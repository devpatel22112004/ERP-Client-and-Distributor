@{
    var InfoJson = ViewBag.JsonData;
}
<div class="p-2">
    <form role="form" id="formMenu" data-toggle="validator">
        <div class="p-2 text-center">
            <span class="delete-record-message" id="btnDeleteMenu"> DELETE PERMANENT RECORDS ? CLICK HERE  <i class="far fa-trash-alt delete-record text-red" title="Delete Record"></i></span>
        </div>
        <div class="row">
            <div class="form-group col-md-6">
                <label for="txtPosition">Position</label>
                <input type="text" class="form-control form-control-sm" id="txtPosition" name="txtPosition" placeholder="Enter Position" data-error="Please Fill Up Position" required>
            </div>
            <div class="form-group col-md-6">
                <label for="txtLabel">Label</label>
                <input type="text" class="form-control form-control-sm" id="txtLabel" name="txtLabel" placeholder="Enter Label" data-error="Please Fill Up Label">
            </div>
            <div class="form-group col-md-6">
                <label for="txtController">Controller</label>
                <input type="text" class="form-control form-control-sm" id="txtController" name="txtController" placeholder="Enter Controller" title="Please Fill Up Controller">
            </div>
            <div class="form-group col-md-6">
                <label for="txtAction">Action</label>
                <input type="text" class="form-control form-control-sm" id="txtAction" name="txtAction" placeholder="Enter Action" title="Please Fill Up Action">
            </div>
            <div class="form-group col-md-6">
                <label for="txtIcon">Icon</label>
                <input type="text" class="form-control form-control-sm" id="txtIcon" name="txtIcon" placeholder="Enter Icon" data-error="Please Fill Up Icon">
            </div>
            <div class="form-group col-md-6">
                <label for="ddStatus">Status <i class="text-red" title="Required">*</i></label>
                <select class="form-control select3 form-control-sm" id="ddStatus" name="ddStatus" data-error="Please Select Status" required>
                    <option selected="selected" value="">-- Select Status ---</option>
                    <option value="Active">Active</option>
                    <option value="Deactive">Deactive</option>
                </select>
            </div>
        </div>
        <div class="form-group text-center col-md-12">
            <input type="hidden" value="" id="hdId" name="hdId" />
            <input type="hidden" value="" id="hdParentId" name="hdParentId" />
            <button type="submit" class="btn btn-default" id="btnsave">Save</button>
        </div>
    </form>
</div>
<script>

     $(function () {

            /*Edit Record */
            var jInfo = @Html.Raw(InfoJson);
            console.log(jInfo);
            if (jInfo != null) {
                $("#hdId").val(jInfo[0].MenuId);
                $("#hdParentId").val(jInfo[0].ParentId);
                $("#txtIcon").val(jInfo[0].Icon);
                $("#txtPosition").val(jInfo[0].Position);
                $("#txtLabel").val(jInfo[0].Label);
                $("#txtController").val(jInfo[0].Controller);
                $("#txtAction").val(jInfo[0].Action);
                $("#ddStatus").val(jInfo[0].Status);
            }
            /* end:Edit Record */

              /* start Form validation & save data */
            var f = $('#formMenu');
            f.validator();// Call validation function
            f.attr('autocomplete', 'off');//Auto Complete Off
            f.submit(function (e) {
                e.preventDefault();
                var button = f.find(':submit');
                var isDisabled = button.is('.btn.disabled');
                var redirectUrl = '/Menu/List'; // Eg /Category/List
                if (isDisabled) {
                    return;
                }
                else {
                    sendData(f, "/Menu/Insert", button, button.text(), redirectUrl).then(function (res) {
                         console.log(res)
                    });
                }
            });
         /* end Form */


         /*Delete Action*/
         $('#btnDeleteMenu').on('click', function (e) {
             confirmDialog('Are you sure to delete record ?', function () {
                 var recordId = $("#hdId").val();
                 sendData(f, "/Menu/Delete?id=" + recordId, $(this), $(this).text(), "/Menu/List");
             });
         });
     });

</script>
