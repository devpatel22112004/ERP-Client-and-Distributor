@{
    ViewBag.Title = "Bank List";

}

<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2" id="filter_Bank">
            <span class="text-sm">Search Record</span>
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="0" id="txtSearchCompanyName" name="txtSearchCompanyName" placeholder="Type Company Name">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="1" id="txtSearchBankName" name="txtSearchBankName" placeholder="Type Bank Name">
                    </div>
                </div>
                <div class="form-group col-md-3">
                    <select class="form-control form-control-sm select3 column_filter" data-column="2" id="ddSearchAccountType" name="ddSearchAccountType" title="Please Selected Account Type">
                        <option value="" selected="selected">---Selected Account Type---</option>
                        <option value="Saving">Saving</option>
                        <option value="Current">Current</option>
                    </select>
                </div>
                <div class="form-group col-md-3">
                    <select class="form-control form-control-sm select3 column_filter" data-column="3" id="ddSearchStatus" name="ddSearchStatus" title="Please Selected Status">
                        <option value="" selected="selected">---Selected Status---</option>
                        <option value="True">Active</option>
                        <option value="False">Deactive</option>
                    </select>
                </div>
                <div class="col-md-12 text-center">
                    <span id="btnListSearch" class="btn btn-outline-secondary btn-sm" title="Filter"><i class="fas fa-filter"></i></span>
                    <span id="btnListRefresh" class="btn btn-outline-secondary btn-sm" title="Reset"><i class="fas fa-sync-alt"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Bank List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormBank" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <!-- /.card-header -->
            <div class="card-body small table-responsive p-2" style="height: 70vh;">
                <table class="table table-striped table-sm no-footer table-borderless table-hover table-head-fixed table-responsive-card" id="myTableBank">
                    <!--table table-head-fixed-->
                    <thead>
                        <tr>
                            <th>BankName</th>
                            <th>NameOfHolder</th>
                            <th>Account No</th>
                            <th>Account Type</th>
                            <th>Opening Date</th>
                            <th>Opening Balance</th>
                            <th>Remark</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>
@section footer{
    <script>
        var oTableBank;
        function filterColumn(i, tag) {
            oTableBank.DataTable().column(i).search(
                tag.val()
            ).draw();
        }
        $(function () {
            $(".master,.master-Bank").addClass('active');

            /* Aditional Filter */
            $('input.column_filter,select.column_filter').on('keyup change', function () {
                filterColumn($(this).attr('data-column'), $(this));
            });

            BindTableBank(); // Bind table

            //refresh button
            $('#btnListRefresh').click(function () {
                oTableBank.DataTable().state.clear();
                location.reload();
            });

            $('#btnFormBank').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New Bank", "/Bank/Form", "modal-lg");
            });
        });

        function BindTableBank() {
            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "Edit";
            oTableBank = bindTableSmart($('#myTableBank'), activeButtonClass, "/Bank/LoadData", "null", $("#filter_Bank")); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableBank.on('click', '.edit-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Edit?id=" + recordId, "modal-lg");// Model Size : modal-sm modal-md modal-lg
            });
        }
    </script>
}






