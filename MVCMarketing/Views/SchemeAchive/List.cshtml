@{
    ViewBag.Title = "SchemeAchive List";
}

<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2" id="filter_SchemeAchive">
            <div class="row">
                <div class="form-group col-md-2">
                    <input type="text" class="form-control form-control-sm column_filter" data-column="2" id="txtSearchLabel" name="txtSearchLabel" placeholder="Search Label">
                </div>
                <div class="form-group col-md-2">
                    <input type="text" class="form-control form-control-sm column_filter" data-column="0" id="txtSearchStartDate" name="txtSearchStartDate" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" placeholder="Search Start Date">
                </div>
                <div class="form-group col-md-2">
                    <input type="text" class="form-control form-control-sm column_filter" data-column="1" id="txtSearchEndDate" name="txtSearchEndDate" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" placeholder="Search End Date">
                </div>
                <div class="col-md-3">
                    <button type="button" class="btn btn-default btn-sm" id="btnSearch" title="Search"><i class="fas fa-filter"></i></button>
                    &nbsp;
                    <button type="button" class="btn btn-default btn-sm" id="btnListRefresh" title="Refresh"><i class="fas fa-sync-alt"></i></button>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-header border-0">
                <h3 class="card-title">Scheme Achive List</h3>
            </div>
            <div class="card-body table-responsive small p-2" style="height: 70vh;">
                <table id="myTableSchemeAchive" class="table table-sm table-striped table-borderless table-hover table-head-fixed table-responsive-card">
                    <thead>
                        <tr>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Label</th>
                            <th>Tag</th>
                            <th>Min Amount</th>
                            <th>Max Amount</th>
                            <th>Description</th>
                            <th>T&C</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>
@section footer{

    <script>
        var oTableSchemeAchive;
        function filterColumn(i, tag) {
            oTableSchemeAchive.DataTable().column(i).search(
                tag.val()
            ).draw();
        }
        $(function () {
            $(".Scheme,.Scheme-SchemeAchive").addClass('active');

            /* Aditional Filter */
            $('input.column_filter,select.column_filter').on('keyup change', function () {
                filterColumn($(this).attr('data-column'), $(this));
            });

            BindTableSchemeAchive();// Bind table

            //Date picker
            $('#txtSearchStartDate,#txtSearchEndDate').datepicker({
                format: "dd-mm-yyyy",
                todayHighlight: true,
                autoclose: true
            });
            //Datemask dd/mm/yyyy
            $('#txtSearchStartDate,#txtSearchEndDate').inputmask('dd-mm-yyyy', { 'placeholder': 'dd-mm-yyyy' })


            //refresh button
            $('#btnListRefresh').click(function () {
                oTableSchemeAchive.DataTable().state.clear();
                location.reload();
            });

            $('#btnFormSchemeAchive').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New SchemeAchive", "/SchemeAchive/Form", "modal-md");
            });
        });

        function BindTableSchemeAchive() {
            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "";
            oTableSchemeAchive = bindTableSmart($('#myTableSchemeAchive'), activeButtonClass, "/SchemeAchive/LoadData", "null", $("#filter_SchemeAchive")); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableSchemeAchive.on('click', '.edit-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Edit?id=" + recordId, "modal-md");// Model Size : modal-sm modal-md modal-lg
            });
        }

    </script>

}
