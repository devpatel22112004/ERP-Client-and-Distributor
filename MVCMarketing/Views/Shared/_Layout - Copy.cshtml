    <script>
        $(document).ready(function () {
            $("form,input").attr('autocomplete', 'off'); // Switching form autocomplete attribute to off
            /* The jQuery way */
            window.setInterval(keepAlive, 300000); /*5 minutes would be 5 * 60 * 1000 = 300000 */

            $(document).on('keyup keypress', 'form input[type="text"]', function (e) {
                if (e.which == 13) {
                    e.preventDefault();
                    return false;
                }
            });
        });

        /**/
        function toastMessage(type, title) {
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 5000
            });
            Toast.fire({
                type: type.toLowerCase(),
                title: title
            });
        }

        /*start: View Modal*/
        function viewModal(divTitle, viewDiv, divUrl) {
            viewDiv.find('.div-title').html(divTitle);
            viewDiv.find('.div-body').html('');
            viewDiv.find('.div-body').load(divUrl);
            /*partialView.on('shown.bs.modal', function () {
                partialView.find('input[type="text"]:first,textarea:first').focus();
            });*/
        }
        /*stop*/

        /*start: View Modal*/
        function viewPartialViewModal(modalTitle, modalUrl, modelSize) {
            var partialView = $('#myModalPartialView');
            partialView.modal('show');
            partialView.find('.modal-title').html(modalTitle);
            partialView.find('.modal-dialog').addClass(modelSize);
            partialView.find('.modal-body').html('<div class="text-center p-5">Loading..... Please Wait <p>');
            partialView.find('.modal-body').load(modalUrl);
            /*partialView.on('shown.bs.modal', function () {
                partialView.find('input[type="text"]:first,textarea:first').focus();
            });*/
        }
        /*stop*/

