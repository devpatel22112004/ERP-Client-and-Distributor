        function sendData(myForm, myUrl, myButton, myButtonText, redirectUrl) {
            var data = null;
            if (myForm != null) {
                data = myForm.serialize({ checkboxesAsBools: true });
                myForm.find("input, button, submit, textarea, select").attr("disabled", "disabled");
                myButton.text("Please Wait...");
            }
            return $.ajax(
                {
                    type: "POST", //HTTP POST Method
                    url: myUrl, // Controller/View
                    data: data,
                    success: function (obj) {
                        if (myForm != null) {
                            myButton.text(myButtonText);
                            myForm.find("input, button, submit, textarea, select").removeAttr("disabled");
                        }
                        //Toast message
                        toastMessage(obj.status, obj.message);
                        if (obj.status == 'success') {
                            if (redirectUrl != '')
                                window.location = redirectUrl;
                            else
                                return (obj.idValue);
                        }
                        /*else if (obj.status == 'Duplicate') {
                            return 'Duplicate';
                        }
                        else {
                            return 'Error';
                        }*/

                    },
                    error: function () {
                    }
                });
        }
