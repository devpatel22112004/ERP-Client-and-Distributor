        //DropDownClass
        /*start: DropDown*/
        async function bindDropDownList($DropDrown, $DropDownUrl, $DropDownRef = 0) {
            $DropDrown.children('option:not(:first)').remove(); // Remove All Options Except The First
            var myDrownData = $DropDrown;
            var Url = "/api/BindList/DropDown?action=" + $DropDownUrl + "&refId=" + $DropDownRef;
            await $.ajax(
                {
                    type: "POST", //HTTP POST Method
                    url: Url,
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    async: false,
                    success: function (data) {
                        var d = JSON.parse(data);
                        console.log(d);
                        $(d).each(function () {
                            var option = $("<option />");
                            option.html(this.Text);//Set Text
                            option.val(this.Value);//Set Value
                            myDrownData.append(option);//Add the Option element to DropDownList.
                        });
                    },
                    error: function () {
                    }
                });
        }
