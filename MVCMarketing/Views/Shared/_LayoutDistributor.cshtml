        /* start : Bind menu sub-menu */
        function recurse(obj, subMenu, masterClass) {
            $.each(obj, function (idx, objNested) {
                if (objNested.hasOwnProperty("Children")) {
                    var menu = "";
                    $.each(objNested.Children, function (idx, objChildren) {
                        var li_i = "<i class=\"nav-icon " + objChildren.Icon + "\"> </i><p>" + objChildren.Title + "</p>";
                        var li_a = "<a href=\"" + objChildren.Url + "\" class=\"nav-link " + masterClass + "_" + objChildren.Class + "\">" + li_i + "</a>";
                        var li = "<li class=\"nav-item\">" + li_a + "</li>";
                        menu += li;
                    });
                    var li_i = "<i class=\"nav-icon " + objNested.Icon + "\"></i><p>" + objNested.Title + " <i class=\"right fas fa-angle-left\"></i> </p>";
                    var li_a = "<a href=\"" + objNested.Url + "\" class=\"nav-link " + masterClass + "_" + objNested.Class + "\">" + li_i + "</a>";
                    var li_ul = li_a + "<ul class=\"nav nav-treeview\">" + menu + "</ul>";
                    var li = "<li class=\"nav-item has-treeview\">" + li_ul + "</li>";
                    subMenu += li;
                    recurse(objNested.Children, subMenu, masterClass);
                }
                else {
                    var li_i = $("<i class=\"nav-icon " + objNested.Icon + "\"> </i><p>" + objNested.Title + "</p>");
                    var li_a = $("<a href=\"" + objNested.Url + "\" class=\"nav-link " + masterClass + "_" + objNested.Class + "\"></a>").append(li_i);
                    var li = $("<li class=\"nav-item\"></li>").append(li_a);
                    var div = $("<div></div>").append(li);
                    subMenu += div.html();
                }
            });
            return subMenu;
        }
        /* stop : Bind menu sub-menu */

