        //DropDownClass
        /*start: DropDown*/
        async function bindDropDownList($DropDrown, $DropDownUrl, $DropDownRef = 0) {
            $DropDrown.children('option:not(:first)').remove(); // Remove All Options Except The First
            var myDrownData = $DropDrown;
            var Url = "/api/BindList/DropDown?action=" + $DropDownUrl + "&refId=" + $DropDownRef;
            await $.ajax(
                {
                    type: "POST", //HTTP POST Method
                    url: Url,
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    async: false,
                    success: function (data) {
                        var d = JSON.parse(data);
                        $(d).each(function () {
                            var option = $("<option />");
                            option.html(this.Text);//Set Text
                            option.val(this.Value);//Set Value
                            myDrownData.append(option);//Add the Option element to DropDownList.
                        });
                    },
                    error: function () {
                    }
                });
        }
        /*stop: DropDown*/

        /*start : AutoComplete*/
        function customAutoComplete($myAutoComplete, $myAutoCompleteID, $myAutoCompleteAction, $myAutoCompleteRef = 0) {
            $myAutoComplete.autocomplete({
                source: function (request, response) {
                    var URl = "/api/BindList/AutoComplete?prefix=" + request.term.replaceAll(' ', '%20') + "&action=" + $myAutoCompleteAction + "&refId=" + $myAutoCompleteRef;
                    console.log(URl);
                    $.ajax({
                        url: URl,
                        type: "POST",
                        success: function (data) {
                            console.log(data);
                            var d = JSON.parse(data);
                            console.log(d);
                            if (d.length > 0) {
                                response($.map(d, function (item) {
                                    return {
                                        label: item.label,
                                        val: item.val,
                                        description: item.description,
                                        item: item
                                    };
                                }))
                            } else {
                                //If no records found, set the default "No match found" item with value -1.
                                response([{ label: 'No results found.', val: '', description: '' }]);
                            }
                        }
                    });
                },
                select: function (e, u) {
                    //If the No match found" item is selected, clear the TextBox.
                    if (u.item.val == "") {
                        //Clear the AutoComplete TextBox.
                        $(this).val("");
                        $myAutoCompleteID.val("");
                        return false;
                    }
                    else {
                        $myAutoCompleteID.val(u.item.val);
                    }
                    showResult(e, u.item);
                },
                //change: showResult,
                minLength: 3,
                delay: 500
            }).keyup(function (e, data, u) {
                if (e.which == 8 || e.which == 46) {
                    console.log(data);
                    showResult(e, "");
                }
            }).autocomplete("instance")._renderItem = function (ul, item) {
                return $("<li>")
                    .append("<div><span>" +
                        item.label + "</span><br><span class=\"desc\">" +
                        item.description + "</span></div>")
                    .appendTo(ul);
            };
            /*END AutoComplete*/
        }
        /*stop : */

