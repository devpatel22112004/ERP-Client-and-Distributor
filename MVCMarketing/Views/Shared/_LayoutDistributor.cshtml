                modal.modal("hide");
            };
            var modal = $("#confirmModal");
            modal.modal("show");
            $(".confirmMessage").empty().append(message);
            $(".confirmOk").unbind().one('click', onConfirm).one('click', fClose);
            $(".confirmCancel").unbind().one("click", fClose);
        }
