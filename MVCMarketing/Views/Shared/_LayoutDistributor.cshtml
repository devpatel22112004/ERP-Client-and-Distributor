                     }
                 },
                 select: function (e, u) {
                     //If the No match found" item is selected, clear the TextBox.
                     if (u.item.val == "") {
                         //Clear the AutoComplete TextBox.
                         $(this).val("");
                         $myAutoCompleteID.val("");
                         return false;
                     }
                     else {
                         $myAutoCompleteID.val(u.item.val);
                     }
                     //console.log(func);
                     func(e, u.item);
                 },
                 //change: showResult,
                 minLength: 2,
                 delay: 500
             }).keyup(function (e, data, u) {
                 if (e.which == 8 || e.which == 46) {
                     $myAutoCompleteID.val("");
                 }
             }).autocomplete("instance")._renderItem = function (ul, item) {
                return $("<li>")
                    .append("<div><span>" + item.label + "</span><br><small class=\"small\">" + item.description + "</span></div>")
                    .appendTo(ul);
            };
            /*END AutoComplete*/
        }

        // function is number
        function isNumber(evt, element) {
            var charCode = (evt.which) ? evt.which : event.keyCode
            if (
                (charCode != 45 || $(element).val().indexOf('-') != -1) &&      // “-” CHECK MINUS, AND ONLY ONE.
                (charCode != 46 || $(element).val().indexOf('.') != -1) &&      // “.” CHECK DOT, AND ONLY ONE.
                (charCode < 48 || charCode > 57))
                return false;
            return true;
        }

        function keepAlive() {
            var d = new Date($.now());
            //console.log("IN");
            console.log(d.getDate() + "-" + (d.getMonth() + 1) + "-" + d.getFullYear() + " " + d.getHours() + ":" + d.getMinutes() + ":" + d.getSeconds());
            $.ajax({
                url: "./../mysession.html",
                cache: false,
                success: function () { }
            });
        }

        function modalPrint(titel, url) {
            $('#printDiv').prop('src', url)
            var partialView = $('#myModalPrint');
            partialView.modal('show');
            partialView.find('.modal-title').html(titel);
    }
    /* multiple modal overlay */
    $(document).on('show.bs.modal', '.modal', function () {
        const zIndex = 1040 + 10 * $('.modal:visible').length;
        $(this).css('z-index', zIndex);
        setTimeout(() => $('.modal-backdrop').not('.modal-stack').css('z-index', zIndex - 1).addClass('modal-stack'));
    });

    </script>
</body>
</html>

