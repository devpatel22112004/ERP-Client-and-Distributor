@{ ViewBag.Title = "City List"; }

<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2" id="filter_City">
            <div class="row">

                <div class="form-group col-md-3">
                    <input type="text" class="form-control form-control-sm column_filter" data-column="0" id="txtSearchCity" name="txtSearchCity" placeholder="Search City">
                </div>

                <div class="form-group col-md-3">
                    <select class="form-control form-control-sm select3 column_filter" data-column="1" id="ddSearchState" name="ddSearchstate" title="Please Selected State">
                        <option value="" selected="selected">---- Select State ----</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <button type="button" class="btn btn-default btn-sm" id="btnSearch" title="Search"><i class="fas fa-filter"></i></button>
                    &nbsp;
                    <button type="button" class="btn btn-default btn-sm" id="btnRefresh" title="Refresh"><i class="fas fa-sync-alt"></i></button>
                </div>
            </div>

        </div>
        <div class="card">
            <div class="card-header border-0">
                <h3 class="card-title">City List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormCity" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <div class="card-body table-responsive small p-2" style="height: 70vh;">
                <table id="myTableCity" class="table table-sm table-striped table-borderless table-hover table-head-fixed table-responsive-card">
                    <thead>
                        <tr>
                            <th>City</th>
                            <th>State</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

@section footer{
    <script>
        var oTableCity;
        function filterColumn(i, tag) {
            oTableCity.DataTable().column(i).search(
                tag.val()
            ).draw();
        }
        $(function () {
            $(".master,.master-City").addClass('active');

            /* Aditional Filter */
            $('input.column_filter,select.column_filter').on('keyup change', function () {
                filterColumn($(this).attr('data-column'), $(this));
            });

            bindDropDownList($('#ddSearchState'), 'State');

            BindTableCity(); // Bind table

            //refresh button
            $('#btnRefresh').click(function () {
                oTableCity.DataTable().state.clear();
                location.reload();
            });

            $('#btnFormCity').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New City", "/City/Form", "modal-md");
            });
        });

        function BindTableCity() {
            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "Edit";
            oTableCity = bindTableSmart($('#myTableCity'), activeButtonClass, "/City/LoadData", "null", $("#filter_City")); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableCity.on('click', '.edit-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Edit?id=" + recordId, "modal-md");// Model Size : modal-sm modal-md modal-lg
            });
        }
    </script>
}