@{
    var InfoJson1 = ViewBag.JsonData1;
}
<div class="p-2">
    <div class="row">
        <div class="col-md-12 small-box">
            <div class="p-0">
                <form role="form" data-toggle="validator" id="formConvertToCredit">
                    <div class="form-group col-md-3">
                        <span for="txtReturnAmount">Sales Return Amount</span>
                        <input row="2" type="text" class="form-control form-control-sm" id="txtReturnAmount" name="txtReturnAmount" placeholder="Enter Amount" data-error="Please Fill Up Amount" readonly>
                    </div>
                    <div class="col-12 text-center">
                        <input type="hidden" value="" id="hdSalesReturnId" name="hdSalesReturnId" />
                        <input type="hidden" value="" id="txtDistributorId1" name="txtDistributorId1" />
                    </div>
                </form>
            </div>
        </div>
        <span>Invoice List</span>
        <div class="col-md-12 small-box">
            <div class="p-1">
                <div class="table-responsive" style="height: 25vh;">
                    <table class="table table-striped table-sm small no-footer table-borderless table-hover table-head-fixed nowrap" id="myTableReturnInvoice">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Invoice No.</th>
                                <th>Invoice Amount</th>
                                <th>Received Amount</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
        <span>Unmaped Invoice List</span>
        <div class="col-md-12 small-box">
            <div class="p-1">
                <div class="row">
                    <div class="form-group col-xl-3">
                        <input type="text" class="form-control form-control-sm" id="txtSearchInvoiceNumber" name="txtSearchInvoiceNumber" placeholder="Search Invoice Number">
                    </div>
                    <div>
                        <span id="btnListSearchModel1" class="btn btn-outline-secondary btn-sm" title="Filter"><i class="fas fa-filter"></i></span>
                        <button type="button" class="btn btn-default btn-sm" id="btnListRefreshModel1" title="Refresh"><i class="fas fa-sync-alt"></i></button>
                    </div>
                </div>
                <div class="table-responsive" style="height: 25vh;">
                    <table class="table table-striped table-sm small no-footer table-borderless table-hover table-head-fixed nowrap" id="myTableUnmapDealeInvoiceDetails">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Invoice No.</th>
                                <th>Credit Days</th>
                                <th>Over Due</th>
                                <th>Amount</th>
                                <th>Received Amount</th>
                                <th>Running Out. Amount</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
        <div id="myModalReturnInvoice" class="modal fade" data-backdrop="static" aria-modal="true" style="padding-right: 10px; z-index:1052">
            <div class="modal-dialog modal-lg">
                <!-- Modal content-->
                <div class="modal-content">
                    <div class="modal-header bg-gradient-gray">
                        <h5 class="card-title"> Return Invoice Map</h5>
                        <button type="button" class="close" aria-label="Close" id="btnReturnInvoice">
                            <span aria-hidden="true">×</span>
                        </button>
                    </div>
                    <!-- /.box-header -->
                    <div class="modal-body">
                        <div class="col-md-12 small-box p-1">
                            <div class="col-12 text-center bg-transparent">
                                <span class="delete-record-message hidden" id="btnDeletePaymentReturn"> DELETE PERMANENT RECORDS ? CLICK HERE  <i class="far fa-trash-alt delete-record text-red" title="Delete Record"></i></span>
                            </div>
                            <form role="form" data-toggle="validator" id="formInvoiceReturnAmount">
                                <div class="row">
                                    <div class="form-group col-md-4">
                                        <span for="txtSalesReturnAmount">Sales Return Amount</span>
                                        <input type="text" class="form-control form-control-sm" id="txtSalesReturnAmount" name="txtSalesReturnAmount" placeholder="Enter Payment Amount" data-error="Please Fill Up Payment Amount" readonly>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <span for="txtSettleInvoiceAmount">Settle Amount</span>
                                        <input type="text" class="form-control form-control-sm" id="txtSettleInvoiceAmount" name="txtSettleInvoiceAmount" placeholder="Enter Settle Amount" data-error="Please Fill Up Settle Amount" readonly>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <span for="txtRemainingInvoiceAmount">Remaining Amount</span>
                                        <input type="text" class="form-control form-control-sm" id="txtRemainingInvoiceAmount" name="txtRemainingInvoiceAmount" placeholder="Enter Remaining Amount" data-error="Please Fill Up Remaining Amount" readonly>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="form-group col-md-4">
                                        <span for="txtAmount">Invoice Amount <i class="text-red" title="Required">*</i></span>
                                        <input type="text" class="form-control form-control-sm" id="txtAmount" name="txtAmount" placeholder="Enter Amount" data-error="Please Fill Up Amount" readonly>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <span for="txtReceivedAmount">Received Amount <i class="text-red" title="Required">*</i></span>
                                        <input type="text" class="form-control form-control-sm" id="txtReceivedAmount" name="txtReceivedAmount" placeholder="Enter Received Amount" data-error="Please Fill Up Received Amount" required>
                                    </div>
                                    <div class="col-12 text-center">
                                        <input type="hidden" value="" id="hdSRInvoiceId" name="hdSRInvoiceId" />
                                        <input type="hidden" value="" id="hdSRSalesReturnId" name="hdSRSalesReturnId" />
                                        <button type="submit" class="col-md-3 btn btn-dark btn-sm col-4">Save</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    var returnId = "";
    var oTableAccountLedger;
    $(function () {

        /*Edit Record */
            var jInfo = @Html.Raw(InfoJson1);
            console.log(jInfo);
            if (jInfo != null) {
                $("#hdSalesReturnId").val(jInfo[0].SalesReturnId);
                $("#txtReturnAmount").val(jInfo[0].Amount);
                $("#txtDistributorId1").val(jInfo[0].DistributorId);
            }
        /* end:Edit Record */

        $("#btnReturnInvoice").click(function (event) {
            $('#myModalReturnInvoice').modal('hide');
        });

        BindTableDealerInvoice();
        BindTableDealerInvoiceReturn();

        //Set search trigger
        $("#txtSearchInvoiceNumber").on('keyup change', function (e) {
            var thisId = $(this).attr("Id");
            if (e.which == 13 || thisId.includes("dd")) {
                $('#btnListSearchModel1').trigger('click');
            }
        });

        //refresh button
        $('#btnListRefreshModel1').click(function () {
            $('#txtSearchInvoiceNumber').val('');
            $('#btnListSearchModel1').trigger('click');
        });

        //Apply Custom search on jQuery DataTables here
        $('#btnListSearchModel1').click(function () {
            BindTableDealerInvoice();
        });

        /* start Form validation & save data */
        var formReturn = $('#formInvoiceReturnAmount');
        formReturn.validator();// Call validation function
        formReturn.attr('autocomplete', 'off');//Auto Complete Off
        formReturn.submit(function (e) {
            e.preventDefault();
            var button = formReturn.find(':submit');
            var isDisabled = button.is('.btn.disabled');
            var redirectUrl = ''; // Eg /Category/List
            if (isDisabled) {
                return;
            }
            else {

                sendData(formReturn, "/SalesReturn/InsertReturnAmount", button, button.text(), redirectUrl).then(function (res) {
                    $('#myModalReturnInvoice').modal('hide');
                    BindTableDealerInvoice();
                    BindTableDealerInvoiceReturn();
                });
            }
        });
        /* end Form */

        /* function validation qty*/
        $("#txtReceivedAmount").focusout(function () {
            if (parseFloat($("#txtSettleInvoiceAmount").val()) == parseFloat($("#txtSalesReturnAmount").val())|| parseFloat($("#txtReceivedAmount").val()) <= 0)  {
                $("#txtReceivedAmount").val("");
                $("#txtReceivedAmount").focus();
                toastMessage('warning', 'this return invoice hase been already settled.');
            }
        });

        //"edit-record,delete-record,view-record,info-record"
            $('#myTableReturnInvoice').on('click', '.delete-record', function () {
                var recordId = $(this).attr('data-id');
                confirmDialog('Are you sure to delete record ?', function () {
                    sendData($("#formMenuAssing"), "/SalesReturn/DeleteReturn?id=" + recordId, $(this), $(this).text(), "").then(function (res) {
                        BindTableDealerInvoiceReturn();//Bind Data table
                    });
                });
            });

        /*start : Item Edit*/
        $("#myTableUnmapDealeInvoiceDetails").on('click', '.edit-record', function () {
            $('#formInvoiceReturnAmount').find("input").val("");
            $("#hdSRSalesReturnId").val($('#hdSalesReturnId').val());
            $("#hdSRInvoiceId").val($(this).attr('data-id'));
            $('#myModalReturnInvoice').modal('show');
            EditData("/SalesReturn/CreditDiscount?id=" + $("#hdSRInvoiceId").val() + "&returnId=" + $("#hdSRSalesReturnId").val());
        });
        /*stop*/

        /*Delete Action*/
        $('#btnDeletePaymentReturn').on('click', function (e) {
            confirmDialog('Are you sure to delete record ?', function () {
                var recordId = $("#hdSRInvoiceId").val();
                sendData($("#formDelete"), "/SalesReturn/DeleteCreditDiscount?id=" + recordId, $(this), $(this).text(), "").then(function (res) {
                    $('#myModalReturnInvoice').modal('hide');
                    BindTableInvoiceItem();
                });//, "/Category/List"
            });
        });
    });

    function BindTableDealerInvoice() {
        $("#myTableUnmapDealeInvoiceDetails > tbody").html("");
        $.ajax(
            {
                type: "POST", //HTTP POST Method
                url: "/SalesReturn/LoadDataInvoice?id=" + $("#txtDistributorId1").val() + '&InvoiceNumber=' + $('#txtSearchInvoiceNumber').val(),
                //data: formData,
                success: function (data) {
                    var d = JSON.parse(data.data);
                    for (var i = 0; i < d.length; i++) {
                        var row = "";
                        row += "<tr>";
                        row += "<td>" + d[i].Date + "</td>";
                        row += "<td>" + d[i].InvoiceNumber + "</td>";
                        row += "<td>" + d[i].CreditDay + "</td>";
                        row += "<td>" + d[i].DueDay + "</td>";
                        row += "<td>" + d[i].Amount + "</td>";
                        row += "<td>" + d[i].Received + "</td>";
                        row += "<td>" + d[i].RunningOutAmount + "</td>";
                        row += "<td  width=\"40px\">";
                        row += "<span type=\"button\" class=\"fas fa-edit edit-record\" title=\"Edit Record\" data-id='" + d[i].InvoiceId + "' data-distributorId='" + d[i].DistributorId + "'></span>";
                        row += "</td>"
                        row += "</td>"
                        row += "</tr>";
                        $('#myTableUnmapDealeInvoiceDetails').find("tbody").append(row);
                    }
                },
                error: function () {

                }
            });
    }

    function BindTableDealerInvoiceReturn() {
        $("#myTableReturnInvoice > tbody").html("");
        $.ajax(
            {
                type: "POST", //HTTP POST Method
                url: "/SalesReturn/LoadDataReturnInvoice?id=" + $("#hdSalesReturnId").val(),
                //data: formData,
                success: function (data) {
                    var d = JSON.parse(data.data);
                    for (var i = 0; i < d.length; i++) {
                        var row = "";
                        row += "<tr>";
                        row += "<td>" + d[i].Date + "</td>";
                        row += "<td>" + d[i].InvoiceNumber + "</td>";
                        row += "<td>" + d[i].Amount + "</td>";
                        row += "<td>" + d[i].ReturnAmount + "</td>";row += "<td  width=\"40px\">";
                        row += "<span type=\"button\" class=\"far fa-trash-alt delete-record\" title=\"Delete Record\" data-id='" + d[i].SalesReturnInvoiceMapId+"'></span>";
                        row += "</td>"
                        row += "</td>"
                        row += "</tr>";
                        $('#myTableReturnInvoice').find("tbody").append(row);
                    }
                },
                error: function () {

                }
            });
    }

    /*start: Edit item*/
    function EditData($Url, $Title) {
        console.log($Url);
        $("#btnDeletePaymentCredit").addClass("hidden");

        $.ajax(
            {
                type: "POST", //HTTP POST Method
                url: $Url, // Controller/View
                success: function (objData) {
                    var obj = JSON.parse(objData);
                    var Return = JSON.parse(obj.data1)[0];
                    var dataPayment = JSON.parse(obj.data2)[0];
                    $("#hdSalesReturnId").val(Return.SalesReturnId);
                    $("#txtAmount").val(dataPayment.InvoiceAmount);
                    $("#txtReceivedAmount").val(Return.ReturnAmount);
                    $("#txtSalesReturnAmount").val(Return.SalesReturnAmount);
                    $("#txtSettleInvoiceAmount").val(Return.SettlementAmount);
                    $("#txtRemainingInvoiceAmount").val(Return.RemainingAmount);
                    editMode = true;
                    $('#myModalReturnInvoice').modal('show');

                },
                error: function () {
                    alert("Error");
                }
            });
    }
        /*stop: Edit item*/
</script>


