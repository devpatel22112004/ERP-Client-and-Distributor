
@{
    var InfoJson = ViewBag.JsonData;
}
<div class="col-12 text-center bg-transparent">
    <span class="delete-record-message" id="btnDeleteInquiryType"> DELETE PERMANENT RECORDS ? CLICK HERE  <i class="far fa-trash-alt delete-record text-red" title="Delete Record"></i></span>
</div>
<div class="p-0">
    <form role="form" data-toggle="validator" id="formInquiryType" class="text-sm">
        <div class="row">
            <div class="col-md-12">
                    <div class="form-group">
                        <label for="txtLable">Label <i class="text-red" title="Required">*</i></label>
                        <input type="text" class="form-control eachWordFirstLetterUpper" id="txtLable" name="txtLable" placeholder="Enter Label" data-error="Please Fill Up Label" required>
                    </div>
                        <div class="form-group">
                            <label for="ddStatus">Status <i class="text-red" title="Required">*</i></label>
                            <select class="form-control select3" id="ddStatus" name="ddStatus" data-error="Please Select Status" required>
                                <option selected="selected" value="">-- Select Status ---</option>
                                <option value="TRUE">Active</option>
                                <option value="FALSE">Deactive</option>
                            </select>
                    </div>
            </div>
        </div>
        <div class="col-12 text-center">
            <hr />
            <input type="hidden" value="" id="hdInquiryTypeId" name="hdInquiryTypeId" />
            <button type="submit" class="col-md-3 btn btn-outline-secondary btn-sm">Save</button>
        </div>
    </form>
</div>
<script>

    $(function () {
        /*Edit Record */
        var jInfo = @Html.Raw(InfoJson);
        console.log(jInfo);
        if (jInfo != null) {
            $("#hdInquiryTypeId").val(jInfo[0].InquiryTypeId);
            $("#txtLable").val(jInfo[0].Lable);
            $("#ddStatus").val(jInfo[0].Status);
        }
        /* end:Edit Record */

    /*Delete Action*/
        $('#btnDeleteInquiryType').on('click', function(e){
            confirmDialog('Are you sure to delete record ?', function () {
                var recordId = $("#hdInquiryTypeId").val();
                sendData($("#formDelete"), "/InquiryType/Delete?id=" + recordId, $(this), $(this).text(), "/InquiryType/List");
            });
        });

        /* start Form validation & save data */
        var f = $('#formInquiryType');
        f.validator();// Call validation function
        f.attr('autocomplete', 'off');//Auto Complete Off
        f.submit(function (e) {
            e.preventDefault();
            var button = f.find(':submit');
            var isDisabled = button.is('.btn.disabled');
            var redirectUrl = '/InquiryType/List'; // Eg /Branch/List
            if (isDisabled) {
                return;
            }
            else {
                sendData(f, "/InquiryType/Insert", button, button.text(), redirectUrl).then(function (res) {
                     console.log(res)
                });
            }
        });
        /* end Form */
    });
</script>
