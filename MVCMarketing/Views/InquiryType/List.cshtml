@{
    ViewBag.Title = "Inquiry Type List";
    Layout = Session["Layout"].ToString();
}

<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2" id="filter_InquiryType">
            <span class="text-sm">Search Record</span>
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group text-sm">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="0" id="txtSearchInquiryType" name="txtSearchInquiryType" placeholder="Type InquiryType">
                    </div>
                </div>
                <div class="col-md-2">
                    <span id="btnListSearch" class="btn btn-outline-secondary btn-sm" title="Filter"><i class="fas fa-filter"></i></span>
                    <span id="btnListRefresh" class="btn btn-outline-secondary btn-sm" title="Reset"><i class="fas fa-sync-alt"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Inquiry Type List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormInquiryType" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <!-- /.card-header -->
            <div class="card-body small p-2" style="height: 70vh;">
                <!--class="card-body table-responsive p-0" style="height: 300px;" nowrap -->
                <table class="table table-striped table-sm no-footer table-borderless table-hover table-head-fixed table-responsive-card" id="myTableInquiryType">
                    <!--table table-head-fixed-->
                    <thead>
                        <tr>
                            <th>Inquiry Type</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>
@section footer{
    <script>
        var oTableInquiryType;
        function filterColumn(i, tag) {
            oTableInquiryType.DataTable().column(i).search(
                tag.val()
            ).draw();
        }
        $(function () {
            $(".master,.master-inquiry-type").addClass('active');

            /* Aditional Filter */
            $('input.column_filter,select.column_filter').on('keyup change', function () {
                filterColumn($(this).attr('data-column'), $(this));
            });

            BindTableInquiryType();//Bind table

            //refresh button
            $('#btnListRefresh').click(function () {
                oTableInquiryType.DataTable().state.clear();
                location.reload();
            });

            $('#btnFormInquiryType').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New Inquiry Type", "/InquiryType/Form", "modal-md");
            });

        });

        function BindTableInquiryType() {

            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "Edit";
            oTableInquiryType = bindTableSmart($('#myTableInquiryType'), activeButtonClass, "/InquiryType/LoadData", "null", $("#filter_InquiryType")); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableInquiryType.on('click', '.edit-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Edit?id=" + recordId, "modal-md");// Model Size : modal-sm modal-md modal-lg
            });

        }

    </script>

}






