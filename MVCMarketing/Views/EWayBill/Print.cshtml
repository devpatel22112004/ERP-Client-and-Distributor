@{
    ViewBag.Title = "Print";
    //  Layout = Session["Layout"].ToString();
    var InfoJsonHead = ViewBag.JsonDataHead;
    var InfoJsonBody = ViewBag.JsonDataBody;
    Layout = "~/Views/Shared/_Print.cshtml";
}
<style>

    .dark-transparent-line {
        border: none;
        width: 100%;
        margin: 0;
        padding: 0;
        height: 10px; /* Adjust the height as needed */
        background-color: rgba(0, 0, 0, 0.5); /* Dark color with 50% transparency */
    }
</style>
<!-- Summary Page -->
<div class="col-md-12">
    <div class="row no-print">
        <div class="col-md-10"></div>
        <div class="col-md-2 p-1">
            <a class="btn btn-default btn-sm" id="btnPrint"><i class="fas fa-print"></i> Print</a>
            <a class="btn btn-default btn-sm" id="btnPdfDownload" title="Pdf Download"><i class="fas fa-file-pdf"></i> PDF</a>
        </div>
    </div>
</div>

<div class="invoice p-1 mb-3">
    <div class="col-12 table-responsive" id="dvPrint">
        <table class="table-child">
            <tbody>
                <tr>
                    <td style="text-align: center">
                        <h2><strong><span class="lbcompany"></span></strong></h2>
                        <p>
                            Date:<span class="lbstartdate"></span><br />
                        </p>
                    </td>
                </tr>
                <tr>
                    <td class="dark-transparent-line">PART-A</td>
                </tr>
                <tr>
                    <td style="vertical-align: top;">
                        <p>
                            E-Way Bill No:
                        </p>
                        <p>
                            E-Way Bill Date:
                        </p>
                        <p>
                            Generated By:
                        </p>
                        <p>
                            Valid From:
                        </p>
                        <p>
                            Valid Until:
                        </p>
                    </td>
                </tr>
                <tr>
                    <td style="vertical-align: top;">
                        <p>GSTIN of Supplier
                        </p>
                        <p>Place of Dispatch
                        </p>
                        <p> GSTIN of Recipient
                        </p>
                        <p> Place of Delivery
                        </p>
                        <p> Document No.
                        </p>
                        <p>Value of Goods
                        </p>
                        <p>Transaction Type</p>
                        <p>HSN Code</p>
                        <p>Reason for Transportation Outward</p>
                    </td>
                </tr>
                <tr>
                    <td class="dark-transparent-line">PART-B</td>
                </tr>
            </tbody>
        </table>
        <table class="table table-bordered" id="tableItem">
            <thead>
                <tr>
                    <td align="center" colspan="5">
                        <h4>Transporter</h4><br>
                    </td>
                </tr>
                <tr class="text-center">
                    <th style="vertical-align: middle;width: 10%">Mode</th>
                    <th style="vertical-align: middle;width: 10%">Vehicle / Trans Doc No & Dt</th>
                    <th style="vertical-align: middle;width: 10%">From</th>
                    <th style="vertical-align: middle;width: 10%">Entered Date</th>
                    <th style="vertical-align: middle;width: 10%">Entered By</th>
                </tr>
            </thead>
            <tbody class="text-center"></tbody>
        </table>
        <hr />
    </div>
</div>

<!-- /.invoice -->
@section footer{
    <!--Convert Number to Words-->
    <script type="text/javascript" language="javascript" src="~/Scripts/jquery.num2words.js"></script>
    <script>
        var taxMode = 'NO APPLY' , total = 0, discount =0, discountAmount =0,discountTotal = 0, gst = 0,amount = 0,freight = 0;
        var pdfName = "Default";
        $(function () {
            $(".Scheme,.Scheme-Scheme").addClass('active');

            $("#btnPrint").show();
            $("#btnPrint").click(function () {
                $("#btnPrint,.main-footer").hide();
                window.print();
                $('#btnPrint,.main-footer').delay(500).show(0);
            });

            $("#btnPdfDownload").click(function () {
                makePdf("dvPrint", "invoicePrintCss"); //
            });

            var jInfoHead = JSON.parse(JSON.stringify(@Html.Raw(InfoJsonHead)));

            var jInfoBody = JSON.parse(JSON.stringify(@Html.Raw(InfoJsonBody)));

            /*Edit Record */
            console.log(jInfoHead);
            if (jInfoHead != null) {

                $(".lbstartdate").html(jInfoHead[0].StartDate);
                $(".lbenddate").html(jInfoHead[0].EndDate);
                $("#lbgracedate").html(jInfoHead[0].Grace);
                $("#divTerms").html(jInfoHead[0].TermsAndCondition.split("\n").join("<br />"));

                $(".lbcompany").html(jInfoHead[0].CompanyName);
                $(".lbcompanyaddress").html(jInfoHead[0].CompanyAddress);
                $(".lbcompanyemail").html(jInfoHead[0].CompanyEmail);
            }
            });

        function printItems(jInfoBody) {
            var table = $("#tableItem");
            table.find("tbody").html("");
            var index = 0;
            for (j = 0, index = 1; j < jInfoBody.length; j++ , index++) {
                var row = "";
                row += "<tr>";
                //var jsonItemLength = Object.keys(jInfoBody[j]).length;
                var cellCount = 0;
                $.each(jInfoBody[j], function (itemKey, itemVal) {
                    if (cellCount == 3) {
                        row += "<td style=\"vertical-align: middle; text-align:center\">" + itemVal + "</td>";
                    }
                    else
                        row += "<td style=\"vertical-align: middle\">" + itemVal + "</td>";
                    cellCount++;
                });
                row += "</tr>";
                table.append(row);
            }
            for (iExtra = index; iExtra <= 0;   iExtra++) {
                var row = "";
                row += "<tr>";
                for (jExtra = 0; jExtra <=0; jExtra++) {
                    row += "<td></td>";
                }
                row += "</tr>";
                table.append(row);
            }

        }
    </script>
}

