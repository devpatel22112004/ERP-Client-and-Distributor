<div class="p-2">
    <form role="form" data-toggle="validator" id="formSubCategory" class="text-sm">
        <div class="col-md-12">
            <div class="form-group">
                <label for="ddCategory">Category <i class="text-red" title="Required">*</i></label>
                <select class="form-control  form-control-sm" id="ddCategory" name="ddCategory" data-error="Please Selected Category" required>
                    <option value="" selected="selected">--Selected Category--</option>
                </select>
            </div>
            <div>
                <label for="txtSubCategory">Label <i class="text-red" title="Required">*</i></label>
                <input type="text" class="form-control form-control-sm" id="txtLabel" name="txtLabel" placeholder="Enter Label" data-error="Please Fill Up Label" required>
            </div>
        </div>
        <div class="col-md-12">
            <div class="form-group">
                <label for="ddStatus">Status <i class="text-red" title="Required">*</i></label>
                <select class="form-control select3  form-control-sm" id="ddStatus" name="ddStatus" data-error="Please Select Status" required>
                    <option value="">-- Select Status ---</option>
                    <option selected="selected" value="TRUE">Active</option>
                    <option value="FALSE">Deactive</option>
                </select>
            </div>
        </div>
        <div class="col-12 text-center">
            <hr />
            <input type="hidden" value="" id="hdId" name="hdId" />
            <button type="submit" class="col-md-3 btn btn-outline-secondary btn-sm">Save</button>
        </div>
    </form>
</div>
<script>
    $(function () {

        bindDropDownList($('#ddCategory'), 'Category');


        /* start Form validation & save data */
        var f = $('#formSubCategory');
        f.validator();// Call validation function
        f.attr('autocomplete', 'off');//Auto Complete Off
        f.submit(function (e) {
            e.preventDefault();
            var button = f.find(':submit');
            var isDisabled = button.is('.btn.disabled');
            var redirectUrl = '/SubCategory/List'; // Eg /Category/List
            if (isDisabled) {
                return;
            }
            else {
                /*var returnValue = sendData(f, "/Category/Insert", button, button.text(), redirectUrl);
                console.log(returnValue);*/
                sendData(f, "/SubCategory/Insert", button, button.text(), redirectUrl).then(function (res) {
                    console.log(res)
                });
            }
        });
        /* end Form */
    });</script>
