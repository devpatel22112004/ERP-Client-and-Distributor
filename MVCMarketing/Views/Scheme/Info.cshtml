


@{
    var JsonSchemeId = ViewBag.JsonSchemeId;
}

<div class="p-1">
    <div class="col-md-12">
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header border-0">
                        <h3 class="card-title">Product List</h3>
                        <div class="card-tools">
                            <div class="input-group input-group-sm" style="width: 150px;">
                                <button type="button" id="btnFormSchemeTargetProduct" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="table-responsive" style="height: 40vh;">
                                <table class="table table-striped table-sm small no-footer table-borderless table-hover table-head-fixed table-responsive-card" id="myTableSchemeTargetProduct">
                                    <thead>
                                        <tr>
                                            <th>Category</th>
                                            <th>SubCategory</th>
                                            <th>Item</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header border-0">
                        <h3 class="card-title">Target Scheme List</h3>
                        <div class="card-tools">
                            <div class="input-group input-group-sm" style="width: 150px;">
                                <button type="button" id="btnFormSchemeTarget" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="table-responsive" style="height: 40vh;">
                                <table class="table table-striped table-sm small no-footer table-borderless table-hover table-head-fixed" id="myTableSchemeTarget">
                                    <thead>
                                        <tr>
                                            <th>Scheme Amount</th>
                                            <th>Target Amount</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    var Info_SchemeId = "";

    var oTableSchemeTarget;

    var oTableSchemeTargetProduct;

     $(function () {

         Info_SchemeId = @Html.Raw(ViewBag.JsonSchemeId);

         BindTableSchemeTarget();

         BindTableSchemeTargetProduct();

         $('#btnFormSchemeTarget').click(function () {
             //model size .modal-sm .modal-lg .modal-xl
             viewNestedModalPartialView("New Scheme Target", "/SchemeTarget/Form?id=" + Info_SchemeId, "modal-md");
         });


        $('#btnFormSchemeTargetProduct').click(function () {
             //model size .modal-sm .modal-lg .modal-xl
            viewNestedModalPartialView("New Scheme Target Product", "/SchemeTargetProduct/Form?id=" + Info_SchemeId, "modal-md");
        });
     });

    function BindTableSchemeTarget() {
        //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
        //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
        var activeButtonClass = "Edit";
        var oTableSchemeTarget = bindTableWithoutPagination($('#myTableSchemeTarget'), activeButtonClass, "/SchemeTarget/LoadData?id=" + Info_SchemeId); //Bind Table

        //"edit-record,delete-record,view-record,info-record"
        oTableSchemeTarget.on('click', '.edit-record', function () {
           // var recordId = $(this).closest("td").find("input[type='hidden']").val();
            var recordId = $(this).attr('data-id');
            var recordTitle = $(this).closest("tr").find("td").eq(0).text();
            viewNestedModalPartialView(recordTitle, "/SchemeTarget/Edit?id=" + recordId, "modal-md");// Model Size : modal-sm modal-md modal-lg
        });

        //"edit-record,delete-record,view-record,info-record"
        oTableSchemeTarget.on('click', '.view-record', function () {
            //var recordId = $(this).closest("td").find("input[type='hidden']").val();
            var recordId = $(this).attr('data-id');
            var recordDate = $(this).closest("tr").find("td").eq(0).text();
            var recordTitle = $(this).closest("tr").find("td").eq(1).text();
            viewPartialViewModal(recordDate + ' - ' + recordTitle, "/Scheme/Info?id=" + recordId, "modal-xl");// Model Size : modal-sm modal-md modal-lg
        });
    }

    function BindTableSchemeTargetProduct() {
        //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
        //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
        var activeButtonClass = "Edit";
        var oTableSchemeTargetProduct = bindTableWithoutPagination($('#myTableSchemeTargetProduct'), activeButtonClass, "/SchemeTargetProduct/LoadData?id=" + Info_SchemeId); //Bind Table

        //"edit-record,delete-record,view-record,info-record"
        oTableSchemeTargetProduct.on('click', '.edit-record', function () {
            //var recordId = $(this).closest("td").find("input[type='hidden']").val();
            var recordId = $(this).attr('data-id');
            var recordTitle = $(this).closest("tr").find("td").eq(0).text();
            viewNestedModalPartialView(recordTitle, "/SchemeTargetProduct/Edit?id=" + recordId, "modal-md");// Model Size : modal-sm modal-md modal-lg
        });
    }

</script>