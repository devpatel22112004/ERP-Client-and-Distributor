
@{
    var InfoJson = ViewBag.JsonData;
}

<div class="p-2">
    <form role="form" data-toggle="validator" id="formScheme" class="text-sm">
        <div class="row">
            <div class="form-group col-md-4">
                <label for="txtStartDate">Start Date <i class="text-red" title="Required">*</i></label>
                <input type="text" class="form-control form-control-sm" id="txtStartDate" name="txtStartDate" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" placeholder="Search Start Date">
            </div>
            <div class="form-group col-md-4">
                <label for="txtEndDate">End Date <i class="text-red" title="Required">*</i></label>
                <input type="text" class="form-control form-control-sm" id="txtEndDate" name="txtEndDate" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" placeholder="Search End Date">
            </div>
            <div class="form-group col-md-4">
                <label for="txtGracePeriod">Grace Period <i class="text-red" title="Required">*</i></label>
                <input type="text" class="form-control form-control-sm" id="txtGracePeriod" name="txtGracePeriod" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" placeholder="Search Grace Period">
            </div>
        </div>
        <div class="row">
            <div class="form-group col-md-4">
                <label for="txtLabel">Scheme<i class="text-red" title="Required">*</i></label>
                <input type="text" class="form-control form-control-sm" id="txtLabel" name="txtLabel" placeholder="Enter Scheme" data-error="Please Fill Up Scheme" required">
            </div>
            <div class="form-group col-md-8">
                <label for="txtDescription">Subject<i class="text-red" title="Required">*</i></label>
                <input rows="2" class="form-control  form-control-sm" id="txtDescription" name="txtDescription" placeholder="Enter Subject" data-error="Please Fill Up Subject" required>
            </div>
        </div>
        <div class="form-group col-md-12">
            <label for="txtToc">Terms & Conditions <i class="text-red" title="Required">*</i></label>
            <textarea rows="10" class="form-control  form-control-sm" id="txtToc" name="txtToc" placeholder="Enter Terms & Condition" data-error="Please Fill Up  Terms & Condition" required></textarea>
        </div>
        <div class="col-12 text-center">
            <hr />
            <input type="hidden" value="" id="hdId" name="hdId" />
            <button type="submit" class="col-md-3 btn btn-outline-secondary btn-sm">Save</button>
        </div>
    </form>
</div>
<script>

    $(function () {

        //Date picker
        $('#txtStartDate,#txtEndDate,#txtGracePeriod').datepicker({
            format: "dd-mm-yyyy",
            todayHighlight: true,
            autoclose: true
        });
        //Datemask dd/mm/yyyy
        $('#txtStartDate,#txtEndDate,#txtGracePeriod').inputmask('dd-mm-yyyy', { 'placeholder': 'dd-mm-yyyy' })


        /*Edit Record */
        var jInfo = @Html.Raw(InfoJson);
        console.log(jInfo);
        if (jInfo != null) {
            $("#hdId").val(jInfo[0].SchemeId);
            $("#txtStartDate").val(jInfo[0].StartDate);
            $("#txtEndDate").val(jInfo[0].EndDate);
            $("#txtLabel").val(jInfo[0].Label);
            $("#txtGracePeriod").val(jInfo[0].GracePeriod);
            $("#txtDescription").val(jInfo[0].Description);
            $("#txtToc").val(jInfo[0].TermsAndCondition);
        }
        /* end:Edit Record */



        /* start Form validation & save data */
        var f = $('#formScheme');
        f.validator();// Call validation function
        f.attr('autocomplete', 'off');//Auto Complete Off
        f.submit(function (e) {
            e.preventDefault();
            var button = f.find(':submit');
            var isDisabled = button.is('.btn.disabled');
            var redirectUrl = '/Scheme/List'; // Eg /Category/List
            if (isDisabled) {
                return;
            }
            else {
                sendData(f, "/Scheme/Insert", button, button.text(), redirectUrl).then(function (res) {
                     console.log(res)
                });
            }
        });
        /* end Form */
    });
</script>


