
@{
    var InfoJson = ViewBag.JsonData;
}

    <div class="p-2">
        <form role="form" data-toggle="validator" id="formEvent" class="text-sm">
            <div class="row">
                <div class="form-group col-md-6">
                    <label for="txtDate">Date</label>
                    <input type="text" class="form-control  form-control-sm" id="txtDate" name="txtDate" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" placeholder="Enter Date">
                </div>
                <div class="form-group col-md-6">
                    <label for="txtTime">Time <i class="text-red" title="Required">*</i></label>
                    <input type="text" class="form-control  form-control-sm" id="txtTime" name="txtTime" placeholder="Enter Time" data-error="Please Fill Up Time" required>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="ddTitle">Title <i class="text-red" title="Required">*</i></label>
                        <select class="form-control select2-blue" id="ddTitle" name="ddTitle" data-error="Please Selected Title" required>
                            <option value="" selected="selected">--Selected--</option>
                        </select>
                    </div>
                </div>
                <div class="form-group col-md-6">
                    <label for="txtPlace">Venue<i class="text-red" title="Required">*</i></label>
                    <input class="form-control  form-control-sm" id="txtPlace" name="txtPlace" placeholder="Enter Place" data-error="Please Fill Up Place" required>
                </div>
                <div class="form-group col-md-12">
                    <label for="txtAddress">Place<i class="text-red" title="Required">*</i></label>
                    <textarea rows="2" class="form-control  form-control-sm" id="txtAddress" name="txtAddress" placeholder="Enter Address" data-error="Please Fill Up Address" required></textarea>
                </div>
                <div class="col-12 text-center">
                    <input type="hidden" value="" id="hdId" name="hdId" />
                    <button type="submit" class="col-md-3 btn btn-outline-secondary btn-sm">Save</button>
                </div>
            </div>
        </form>
    </div>
<script>
    $(function () {
        //Date picker
        $('#txtDate').datepicker({
            format: "dd-mm-yyyy",
            todayHighlight: true,
            autoclose: true
        });

        /* Bind Brand */
        bindDropDownList($('#ddTitle'), 'EventGroup');

        //Datemask dd/mm/yyyy
        $('#txtDate').inputmask('dd-mm-yyyy', { 'placeholder': 'dd-mm-yyyy' })

        /*Edit Record */
        var jInfo = @Html.Raw(InfoJson);
        console.log(jInfo);
        if (jInfo != null) {
            $("#hdId").val(jInfo[0].EventId);
            $("#ddTitle").val(jInfo[0].EventGroupId);
            $("#txtDate").val(jInfo[0].Date);
            $("#txtPlace").val(jInfo[0].Venue);
            $("#txtTime").val(jInfo[0].Time);
            $("#txtAddress").val(jInfo[0].Place);
        }
        /* end:Edit Record */

       


        $('#txtTime').daterangepicker({
            timePicker: true,
            singleDatePicker: true,
            timePicker24Hour: true,
            timePickerIncrement: 1,
            timePickerSeconds: false,
            locale: {
                format: 'HH:mm'
            }
        }).on('show.daterangepicker', function (ev, picker) {
            picker.container.find(".calendar-table").hide();
        });

        /* start Form validation & save data */
        var f = $('#formEvent');
        f.validator();// Call validation function
        f.attr('autocomplete', 'off');//Auto Complete Off
        f.submit(function (e) {
            e.preventDefault();
            var button = f.find(':submit');
            var isDisabled = button.is('.btn.disabled');
            var redirectUrl = '/Event/List'; // Eg /Category/List
            if (isDisabled) {
                return;
            }
            else {
                /*var returnValue = sendData(f, "/Category/Insert", button, button.text(), redirectUrl);
                console.log(returnValue);*/
                sendData(f, "/Event/Insert", button, button.text(), redirectUrl).then(function (res) {
                    console.log(res)
                });
            }
        });
        /* end Form */
    });
</script>


