@{
    var InfoJsonEventId = ViewBag.JsonEventId;

}
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header border-0">
                <h3 class="card-title">Event Participant List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormEventParticipant" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="table-responsive" style="height: 60vh;">
                        <table class="table table-striped table-sm small no-footer table-borderless table-hover table-head-fixed table-responsive-card" id="myTablebEventParticipant">
                            <thead>
                                <tr>
                                    <th>Firm</th>
                                    <th>Person Name</th>
                                    <th>Profile</th>
                                    <th>Contact</th>
                                    <th>Address</th>
                                    <th>Area</th>
                                    <th>Email</th>
                                    <th>Created By</th>
                                    <th></th>
                                </tr>
                            </thead>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>

    var oTableEventParticipant;

    var eventParticipantId = "";
    $(function () {

        eventParticipantId = '@Html.Raw(InfoJsonEventId)';

        $('#btnFormEventParticipant').click(function () {
            //model size .modal-sm .modal-lg .modal-xl
            viewNestedModalPartialView("New Event Participant", "/Event/ParticipantForm?id=" + eventParticipantId, "modal-xl");
        });

        BindTableEventParticipant();;// Bind table

    });

    function BindTableEventParticipant() {
        //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
        //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
        var activeButtonClass = "Edit";
        oTableEventParticipant = bindTableWithoutPagination($('#myTablebEventParticipant'), activeButtonClass, "/Event/LoadDataEventParticipant?id=" + eventParticipantId); //Bind Table

        //"edit-record,delete-record,view-record,info-record"
        oTableEventParticipant.on('click', '.edit-record', function () {
            //var recordId = $(this).closest("td").find("input[type='hidden']").val();
            var recordId = $(this).attr('data-id');
            var recordTitle = $(this).closest("tr").find("td").eq(0).text();
            viewNestedModalPartialView(recordTitle, "/Event/EditEvent?id=" + recordId, "modal-xl");// Model Size : modal-sm modal-md modal-lg
        });
    }
</script>