@{
    ViewBag.Title = "Event List";
}

<div class="row">
    <div class="col-md-12">
        <div class="small-box bg-white p-2" id="filter_Event">
            <div class="row">
                <div class="form-group col-md-2">
                    <input type="text" class="form-control form-control-sm column_filter" data-column="1" id="txtSearchDate" name="txtSearchDate" data-inputmask-alias="datetime" data-inputmask-inputformat="dd-mm-yyyy" placeholder="Search Date">
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="0" id="txtSearchTitle" name="txtSearchTitle" placeholder="Search Title">
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <input type="text" class="form-control form-control-sm column_filter" data-column="2" id="txtSearchVenue" name="txtSearchVenue" placeholder="Search Venue">
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="button" class="btn btn-default btn-sm" id="btnSearch" title="Search"><i class="fas fa-filter"></i></button>
                    &nbsp;
                    <button type="button" class="btn btn-default btn-sm" id="btnListRefresh" title="Refresh"><i class="fas fa-sync-alt"></i></button>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-header border-0">
                <h3 class="card-title">Event List</h3>
                <div class="card-tools">
                    <div class="input-group input-group-sm" style="width: 150px;">
                        <button type="button" id="btnFormEvent" class="btn btn-block btn-outline-secondary btn-sm"><i class="glyphicon glyphicon-edit"></i>Add New</button>
                    </div>
                </div>
            </div>
            <div class="card-body table-responsive small p-2" style="height: 70vh;">
                <table id="myTableEvent" class="table table-sm  table-striped table-borderless table-hover table-head-fixed table-responsive-card">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Venue</th>
                            <th>Place</th>
                            <th>Participate</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>
@section footer{

    <script>
        function filterColumn(i, tag) {
            oTableEvent.DataTable().column(i).search(
                tag.val()
            ).draw();
        }


        $(function () {
            $(".Event,.Event-event").addClass('active');

            /* Aditional Filter */
            $('input.column_filter,select.column_filter').on('keyup change', function () {
                filterColumn($(this).attr('data-column'), $(this));
            });

            BindTableEvent(); // Bind table

            //refresh button
            $('#btnListRefresh').click(function () {
                oTableEvent.DataTable().state.clear();
                location.reload();
            });

            $('#btnFormEvent').click(function () {
                //model size .modal-sm .modal-lg .modal-xl
                viewPartialViewModal("New Event", "/Event/Form", "modal-md");
            });

            //Date picker
            $('#txtSearchDate').datepicker({
                format: "dd-mm-yyyy",
                todayHighlight: true,
                autoclose: true
            });
            //Datemask dd/mm/yyyy
            $('#txtSearchDate').inputmask('dd-mm-yyyy', { 'placeholder': 'dd-mm-yyyy' })
            // Scroll to specific row button click event
            $('#btnScrollToRow').click(function () {
                scrollToRow(); // Scroll to row function
            });
        });

        function BindTableEvent() {
            //Button active by class name Eg .edit-record,.delete-record,.view-record,.info-record
            //action Edit,Delete,View,Info //"class on click edit-record,delete-record,view-record,info-record"
            var activeButtonClass = "Edit,View";
            oTableEvent = bindTableSmart($('#myTableEvent'), activeButtonClass, "/Event/LoadData", "null", $("#filter_Event")); //Bind Table

            //"edit-record,delete-record,view-record,info-record"
            oTableEvent.on('click', '.edit-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(0).text();
                viewPartialViewModal(recordTitle, "Edit?id=" + recordId, "modal-md");// Model Size : modal-sm modal-md modal-lg
            });
            oTableEvent.on('click', '.view-record', function () {
                //var recordId = $(this).closest("td").find("input[type='hidden']").val();
                var recordId = $(this).attr('data-id');
                var recordTitle = $(this).closest("tr").find("td").eq(1).text();
                // viewPartialViewModal(recordTitle, "Token?id=" + recordId, "modal-xl");// Model Size : modal-sm modal-md modal-lg
                viewPartialViewModal(recordTitle, "/Event/Info?id=" + recordId, "modal-xl");// Model Size : modal-sm modal-md modal-lg

            });
        }

    </script>

}
